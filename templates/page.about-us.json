      "blocks": {
        "template--16391993786425__3953ff38-1696-4219-b180-15946f529962-quote-1": {
          "type": "quote",
          "settings": {
            "rev_title": "",
            "display_review": true,
            "star_rating": 5,
            "quote": "<p>\" My kids absolutely love the interactive features and vibrant colors of the Wooden toy It's become their favorite toy to play with every day. \"</p>",
