            "authorlink": ""
          }
        },
        "template--16391993786425__3953ff38-1696-4219-b180-15946f529962-quote-2": {
          "type": "quote",
          "settings": {
            "rev_title": "",
            "display_review": true,
            "star_rating": 5,
            "quote": "<p>\" As a parent, finding toys that are both educational and fun is important  to me. The exceeded my expectations - it's been a hit in our  household. \"</p>",
            "image": "",
            "author": "Jennifer Miller / Registered Nurse",
            "authorlink": ""
          }
        },
        "template--16391993786425__3953ff38-1696-4219-b180-15946f529962-quote-3": {
          "type": "quote",
          "settings": {
            "rev_title": "",
            "display_review": true,
            "star_rating": 5,
            "quote": "<p>\" I purchased the for my niece's birthday, and she hasn't stopped playing with it since. It's engaging, and provides  hours of entertainment.\"</p>",
