<link rel="preload" as="style" href="{{ 'component-slider.css' | asset_url }}">
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'social-gallery.css' | asset_url }}">
{{ 'social-gallery.css' | asset_url | stylesheet_tag }}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
    }
  }
{%- endstyle -%}
{%- liquid
    assign show_desktop_slider = false
    if section.settings.enable_desktop_slider
        assign show_desktop_slider = true
    endif
    assign show_mobile_slider = false
    if section.settings.swipe_on_mobile
        assign show_mobile_slider = true
    endif
-%}
<div class="color-{{ section.settings.color_scheme }} gradient {% unless section.settings.arrow_position == 'inline' %}slider-arrow-{{ section.settings.arrow_style }} {% endunless %}">
  <div class="social_gallery section-{{ section.id }}-padding slider-arrow--{{ section.settings.arrow_position }} {% if section.settings.sec_full_width == true %} testi_cont{% endif %}">
    <slider-component class="{% if section.settings.columns_mobile == '1-5' %}airo_cutmob {% endif %} slider-mobile-gutter{% if section.settings.image != blank %} img_with_product {% endif %}">
        {% if section.settings.miniheading != blank or section.settings.title != blank or section.settings.description != blank or show_desktop_slider and section.settings.arrow_position == 'top' %}
          <div class="heading-top slider-arrow-{{ section.settings.arrow_style }} {{ section.settings.heading_alignment }} page-width">
            <div class="heading {{ section.settings.heading_alignment }}">
              {%- if section.settings.miniheading != blank -%}
                <span class="{{ section.settings.heading_alignment }}">
                  <span class="offer_pills {% if section.settings.mini_heading_style == 'button' %}offer_pills_button {% elsif section.settings.mini_heading_style == 'outline' %}offer_pills_outline {% else section.settings.mini_heading_style == 'link' %}offer_pills_link {% endif %} rte">
                    {{ section.settings.miniheading }}
                  </span>
                </span>
              {%- endif %}
              {%- if section.settings.title != blank -%}
                <h2 class="{{ section.settings.heading_size }}">
                    {{ section.settings.title }}
                </h2>
              {%- endif %}
              {%- if section.settings.description != blank -%}
                <div class="description {{ section.settings.description_style }} rte">
                  {{ section.settings.description -}}
                </div>
              {%- endif %}
            </div>
            {% if section.settings.arrow_position == 'top' %}
              <div class="wb_button_combo {% unless section.settings.show_view_all %}bcombo_auto{% endunless %}">
                  <div class="wb_home_sbtn slider-buttons no-js-hidden {% unless show_desktop_slider and section.blocks.size > section.settings.columns_desktop %} desktop-arrows-hide {% endunless %}{% if show_desktop_slider and section.blocks.size == 5 and section.settings.columns_desktop == 5 %}desktop-arrows-show{% endif %}{% if section.settings.columns_desktop == 2 %}{% unless section.blocks.size > 2 %} tablet-arrows-hide{% endunless %}{% elsif section.settings.columns_desktop != 1 %}{% unless section.blocks.size > 3 %} tablet-arrows-hide{% endunless %}{% endif %}{% unless show_mobile_slider and section.blocks.size > 1 %} mobile-arrows-hide {% endunless %}">
                    <button
                      type="button"
                      class="slider-button slider-button--prev button"
                      name="previous"
                      aria-label="{{ 'general.slider.previous_slide' | t }}"
                      id="slider-button--prev-{{ section.id }}"
                      aria-controls="slider-button--prev-{{ section.id }}">
                      {% render 'icon-caret' %}
                  </button>
                  <button
                      type="button"
                      class="slider-button slider-button--next button"
                      name="next"
                      aria-label="{{ 'general.slider.next_slide' | t }}"
                      id="slider-button--next-{{ section.id }}"
                      aria-controls="slider-button--next-{{ section.id }}">
                      {% render 'icon-caret' %}
                  </button>
                  </div> 
              </div>
            {% endif %}
          </div>
        {% endif %}
      <div class="slider-arrow-{{ section.settings.arrow_style }} page-width relative post_gallery {% if section.settings.sec_full_width == true %} blog_cont {% endif %}">
        {% if section.settings.arrow_position == 'inline' %}
        <div class="relative"> 
      {% endif %}
        {% if section.settings.arrow_position == 'inline' %}
            <div class="wb_home_sbtn slider-buttons no-js-hidden {% unless show_desktop_slider and section.blocks.size > section.settings.columns_desktop %} desktop-arrows-hide {% endunless %}{% if show_desktop_slider and section.blocks.size == 5 and section.settings.columns_desktop == 5 %}desktop-arrows-show{% endif %}{% if section.settings.columns_desktop == 2 %}{% unless section.blocks.size > 2 %} tablet-arrows-hide{% endunless %}{% elsif section.settings.columns_desktop != 1 %}{% unless section.blocks.size > 3 %} tablet-arrows-hide{% endunless %}{% endif %}{% unless show_mobile_slider and section.blocks.size > 1 %} mobile-arrows-hide {% endunless %}">
              <button
              type="button"
              class="slider-button-inline slider-button slider-button--prev button"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
              id="slider-button--prev-{{ section.id }}"
              aria-controls="slider-button--prev-{{ section.id }}">
              {% render 'icon-caret' %}
          </button>
            </div>
          {% endif %}
        <div id="Slider-{{ section.id }}"
          class="relative grid post_wrapper {% if section.settings.columns_desktop == 3 %} grid--3-col-tablet {% endif %} {% unless section.settings.columns_desktop == 2 %} grid--4-col-tablet {% endunless %} grid--{{ section.settings.columns_desktop }}-col-desktop {% if show_desktop_slider %} slider slider--desktop slider--tablet{% endif %} grid--{{ section.settings.columns_mobile }}-col-tablet-down">
          {%- for block in section.blocks -%}
            <div id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item overlay__wrapper{% if show_desktop_slider %} slider__slide{% endif %}">
              <div class="insta_image global-media-settings">
              {% if block.settings.link != blank and section.settings.button_label == blank -%}
                <a href="{{ block.settings.link }}" title="{{ 'wbcustomlabel.wballtext.banner' | t }}" class="focus-inset"{% if block.settings.link_window %} target="_blank"{% endif %}>
              {%- endif %}
              {% if section.settings.user_heading != blank or section.settings.user_tags != blank or section.settings.button_label != blank or section.settings.icon != 'none' %}
                <div class="content-{{ section.id }} {% if section.settings.user_heading != blank or section.settings.user_tags != blank or section.settings.button_label != blank %}content-overlay{% endif %} color-{{ section.settings.content_color_scheme }}">
                  {% if section.settings.user_heading != blank %}
                    <div class="user_heading">{{ section.settings.user_heading }}</div>
                  {% endif %}
                  {% if section.settings.icon != 'none' and block.settings.link != blank %}
                    <div class="{% if section.settings.user_heading == blank and section.settings.user_tags == blank and section.settings.button_label == blank %}content-details{% endif %} fadeIn-bottom {% if block.settings.enable_icon_bg == false %} bg-transparent{% else %}bg-color{% endif %}">
                    {% render 'icon-socials', icon: section.settings.icon %} 
                    </div>
                  {% endif %}
                  {% if section.settings.user_tags != blank %}
                    <div class="user-tag {{ section.settings.tags_size }}">{{ section.settings.user_tags }}</div>
                  {% endif %}
                  {% if section.settings.button_label != blank %}
                    <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true" {% else %} href="{{ section.settings.button_link }}" {% endif %} {% if section.settings.link_window %} target="_blank" {% endif %}
                      class="{% if section.settings.view_all_style == 'link' %}link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}" {{ section.shopify_attributes }}>
                      {{ section.settings.button_label }}
                    </a>
                  {% endif %}
                  {%- style -%}
                    .post_gallery .overlay__wrapper .content-{{ section.id }}.content-overlay {
                      background-color: rgba(var(--color-background),{{ section.settings.bg_opacity | divided_by: 100.0 }});
                    }
                  {%- endstyle -%}
                </div>
              {% endif %}
              {% if block.settings.image != blank %}
                <img
                  srcset="
                    {%- if block.settings.image.width >= 165 -%}{{ block.settings.image | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if block.settings.image.width >= 360 -%}{{ block.settings.image | image_url: width: 360 }} 360w,{%- endif -%}
                    {% if block.settings.image.width >= 493 %}{{ block.settings.image | image_url: width: 493 }} 493w,{% endif %}
                    {% if block.settings.image.width >= 600 %}{{ block.settings.image | image_url: width: 600 }} 600w,{% endif %}
                    {% if block.settings.image.width >= 713 %}{{ block.settings.image | image_url: width: 713 }} 713w,{% endif %}
                    {% if block.settings.image.width >= 823 %}{{ block.settings.image | image_url: width: 823 }} 823w,{% endif %}
                    {% if block.settings.image.width >= 992 %}{{ block.settings.image | image_url: width: 992 }} 992w,{% endif %}
                    {{ block.settings.image | image_url }} {{ block.settings.image.width }}w
                  "
                  src="{{ block.settings.image | image_url: width: 370 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 992px) calc((100vw - 130px) / 4), (min-width: 768px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  class="post_img lazyload"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {% else %}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'product-apparel-' | append: placeholder_image_index -%}
                <div class="dummysvg">{{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {% endif %}
              {% if block.settings.link != blank and section.settings.button_label == blank %}</a>{% endif %}
              </div>
            </div>
          {%- endfor -%}
        </div>
        {% if section.settings.arrow_position == 'inline' %}
              <div class="wb_home_sbtn slider-buttons no-js-hidden {% unless show_desktop_slider and section.blocks.size > section.settings.columns_desktop %} desktop-arrows-hide {% endunless %}{% if show_desktop_slider and section.blocks.size == 5 and section.settings.columns_desktop == 5 %}desktop-arrows-show{% endif %}{% if section.settings.columns_desktop == 2 %}{% unless section.blocks.size > 2 %} tablet-arrows-hide{% endunless %}{% elsif section.settings.columns_desktop != 1 %}{% unless section.blocks.size > 3 %} tablet-arrows-hide{% endunless %}{% endif %}{% unless show_mobile_slider and section.blocks.size > 1 %} mobile-arrows-hide {% endunless %}">
                <button
                  type="button"
                  class="slider-button-inline slider-button slider-button--next button"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                  id="slider-button--next-{{ section.id }}"
                  aria-controls="slider-button--next-{{ section.id }}">
                  {% render 'icon-caret' %}
              </button>
              </div>
          {% endif %}
      {% if section.settings.arrow_position == 'inline' %}
        </div> 
      {% endif %}
        {% if section.settings.arrow_position == 'bottom' %}
          <div class="top-spacing wb_home_sbtn slider-buttons button-bottom no-js-hidden {% unless show_desktop_slider and section.blocks.size > section.settings.columns_desktop %} desktop-arrows-hide {% endunless %}{% if show_desktop_slider and section.blocks.size == 5 and section.settings.columns_desktop == 5 %}desktop-arrows-show{% endif %}{% if section.settings.columns_desktop == 2 %}{% unless section.blocks.size > 2 %} tablet-arrows-hide{% endunless %}{% elsif section.settings.columns_desktop != 1 %}{% unless section.blocks.size > 3 %} tablet-arrows-hide{% endunless %}{% endif %}{% unless show_mobile_slider and section.blocks.size > 1 %} mobile-arrows-hide {% endunless %}">
            <button
            type="button"
            class="slider-button slider-button--prev button"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            id="slider-button--prev-{{ section.id }}"
            aria-controls="slider-button--prev-{{ section.id }}">
            {% render 'icon-caret' %}
            </button>
            <button
                type="button"
                class="slider-button slider-button--next button"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                id="slider-button--next-{{ section.id }}"
                aria-controls="slider-button--next-{{ section.id }}">
                {% render 'icon-caret' %}
            </button>
          </div>
        {% endif %}
      </div>
      </slider-component>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.Social_media_gallery.name",
  "tag": "section",
  "class": "section-spacing spaced-section",
  "max_blocks": 12,
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "aside",
      "custom.overlay"
    ]
  },
  "settings": [
        {
      "type": "checkbox",
      "id": "sec_full_width",
      "label": "t:sections.collection-list.settings.sec_full_width.label",
      "default": true,
      "info": "t:sections.collection-list.settings.sec_full_width.info"
    },
    {
      "type": "inline_richtext",
      "id": "miniheading",
      "label": "t:sections.collection-list.settings.miniheading.label"
    },
    {
      "type": "select",
      "id": "mini_heading_style",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.mini_heading_style.options__1.label"
        },
        {
          "value": "outline",
          "label": "t:sections.all.mini_heading_style.options__2.label"
        },
        {
          "value": "link",
          "label": "t:sections.all.mini_heading_style.options__3.label"
        }
      ],
      "default": "outline",
      "label": "t:sections.all.mini_heading_style.label"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Heading",
      "label": "t:sections.featured-blog.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h0",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.collapsible_content.settings.heading_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__2.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "t:sections.all.description_style.label",
      "options": [
        {
          "value": "body",
          "label": "t:sections.all.description_style.options__1.label"
        },
        {
          "value": "subtitle",
          "label": "t:sections.all.description_style.options__2.label"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.description_style.options__3.label"
        }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "t:sections.Social_media_gallery.settings.User_description.label"
    },
    {
      "type": "inline_richtext",
      "id": "user_heading",
      "label": "t:sections.collection-list.settings.title.label",
      "default": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "user_tags",
      "label": "t:sections.Social_media_gallery.settings.user_tags.label",
      "default": "#tags"
    },
    {
      "type": "select",
      "id": "tags_size",
      "options": [
        {
          "value": "body",
          "label": "t:sections.image-banner.blocks.text.settings.text_style.options__1.label"
        },
        {
          "value": "subtitle",
          "label": "t:sections.image-banner.blocks.text.settings.text_style.options__2.label"
        }
      ],
      "default": "subtitle",
      "label": "t:sections.Social_media_gallery.settings.tags_size.label"
    },
     {
      "type": "text",
      "label": "t:sections.sponsored-product.settings.button_label.label",
      "id": "button_label",
      "default": "Button label"
    },
    {
      "type": "url",
      "label": "t:sections.sponsored-product.settings.button_link.label",
      "id": "button_link"
    },
    {
      "type": "checkbox",
      "id": "link_window",
      "label": "t:sections.slideshow.blocks.slide.settings.link_window.label",
      "default": true
    },
    {
      "type": "select",
      "id": "view_all_style",
      "label": "t:sections.image-banner.blocks.buttons.settings.button_style_secondary_1.label",
      "options": [
        {
          "value": "link",
          "label": "t:sections.featured-collection.settings.view_all_style.options__1.label"
        },
        {
          "value": "outline",
          "label": "t:sections.featured-collection.settings.view_all_style.options__2.label"
        },
        {
          "value": "solid",
          "label": "t:sections.featured-collection.settings.view_all_style.options__3.label"
        }
      ],
      "default": "link"
    },
    {
      "type": "color_scheme",
      "id": "content_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50,
      "label": "Overlay Background Opacity"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.Social_media_gallery.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "icon",
      "options": [
        {
          "value": "none",
          "label": "t:sections.Social_media_gallery.settings.icon.options__8.label"
        },
        {
          "value": "instagram",
          "label": "t:sections.Social_media_gallery.settings.icon.options__1.label"
        },
        {
          "value": "facebook",
          "label": "t:sections.Social_media_gallery.settings.icon.options__2.label"
        },
        {
          "value": "twitter",
          "label": "t:sections.Social_media_gallery.settings.icon.options__3.label"
        },
        {
          "value": "tiktok",
          "label": "t:sections.Social_media_gallery.settings.icon.options__4.label"
        },
        {
          "value": "vimeo",
          "label": "t:sections.Social_media_gallery.settings.icon.options__5.label"
        },
        {
          "value": "youtube",
          "label": "t:sections.Social_media_gallery.settings.icon.options__6.label"
        },
        {
          "value": "pinterest",
          "label": "t:sections.Social_media_gallery.settings.icon.options__7.label"
        }
      ],
      "default": "instagram",
      "label": "t:sections.Social_media_gallery.settings.icon.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "t:sections.featured-collection.settings.enable_desktop_slider.label",
      "default": true
    },
    {
      "type": "select",
      "id": "arrow_position",
      "options": [
        {
          "value": "top",
          "label": "t:sections.all.arrow_position.options__1.label"
        },
        {
          "value": "inline",
          "label": "t:sections.all.arrow_position.options__2.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.arrow_position.options__3.label"
        }
      ],
      "default": "top",
      "label": "t:sections.all.arrow_position.label"
    },
    {
      "type": "select",
      "id": "arrow_style",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.arrow_style.options__1.label"
        },
        {
          "value": "icon",
          "label": "t:sections.all.arrow_style.options__2.label"
        }
      ],
      "default": "button",
      "label": "t:sections.all.arrow_style.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-3"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header_mobile.content"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": true,
      "label": "t:sections.multicolumn.settings.swipe_on_mobile.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.featured-collection.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label"
        },
        {
          "value": "1-5",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__3.label"
        },
        {
          "value": "2",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.Social_media_gallery.blocks.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.Social_media_gallery.blocks.image_picker.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.Social_media_gallery.blocks.link.label"
        },
        {
          "type": "checkbox",
          "id": "link_window",
          "label": "t:sections.slideshow.blocks.slide.settings.link_window.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "enable_icon_bg",
          "label": "t:sections.Social_media_gallery.blocks.Post_link.label",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    { 
      "name": "t:sections.Social_media_gallery.name",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
