<link rel="preload" as="style" href="{{ 'section-image-banner.css' | asset_url }}">
{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% if section.settings.show_gap %}
    .imagebannermain #Slider-{{ section.id }} {
      column-gap: var(--grid-desktop-horizontal-spacing);
      row-gap: var(--grid-desktop-vertical-spacing);
    }
    @media (max-width: 767px) {
      .imagebannermain #Slider-{{ section.id }} {
        column-gap: var(--grid-mobile-horizontal-spacing);
        row-gap: var(--grid-mobile-vertical-spacing);
      }
    }
  {% else %}
    .imagebannermain #Slider-{{ section.id }} {
        column-gap: 0;
        row-gap: 0;
      }
    .imagebannermain .grid--4-col-desktop .grid__item{
      width: 25%;
      max-width: 25%;
    }
    .imagebannermain .grid--2-col-desktop .grid__item{
      width: 50%;
      max-width: 50%;
    }
    .imagebannermain .grid--3-col-desktop .grid__item{
      width: 33.33%;
      max-width: 33.33%;
    }
  {% endif %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
    }
  }
{%- endstyle -%}


<div class="section-{{ section.id }} section-{{ section.id }}-padding imagebannermain wbimgbnrblock color-{{ section.settings.section_color_scheme }} gradient">
  <div class="{% unless section.settings.full_width == true %} page-width{% endunless %}{% if section.settings.full_width %} section--full-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}{% unless section.settings.enable_sidespace %} section--full-width-withoutspace{% endunless %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade 
    {% endif %}>
    {%- if section.settings.title != blank or section.settings.description != blank -%} 
      <div class="heading-top justify-content-{{ section.settings.heading_alignment }}{% if section.settings.enable_sidespace == false and section.settings.full_width == true %} section--full-width{% endif %}">
        <div class="heading inline-richtext {{ section.settings.heading_alignment }}">
          {%- if section.settings.title != blank -%}
            <h2 class="{{ section.settings.heading_size }}">
                {{ section.settings.title }}
            </h2>
          {%- endif %}
          {%- if section.settings.description != blank -%}
            <div class="{{ section.settings.description_style }} rte">
              {{ section.settings.description -}}
            </div>
          {%- endif %}
        </div>
      </div>
    {%- endif -%}
    <div
  class="banner banner--{{ section.settings.image_height }} grid grid--{{ section.blocks.size }}-col-desktop {% if section.blocks.size == 4 %} grid--2-col-tablet{% endif %} {% if section.blocks.size > 2 %} grid--3-col-tablet{% endif %}" id="Slider-{{ section.id }}">
      {%- for block in section.blocks -%}
          {%- liquid
              if block.settings.image_behavior == 'ambient'
                assign full_width = '120vw'
                assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
              else
                assign full_width = '100vw'
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              endif
            -%}
          <div id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item wb_banner_cover banner--content-align-{{ block.settings.desktop_content_alignment }} banner--content-align-mobile-{{ block.settings.mobile_content_alignment }}" style="{% if section.settings.show_gap %}width: calc({{ block.settings.banner_width }}% - var(--grid-desktop-horizontal-spacing) * {{ section.blocks.size | minus: 1 }} / {{ section.blocks.size }}); max-width: calc({{ block.settings.banner_width }}% - var(--grid-desktop-horizontal-spacing) * {{ section.blocks.size | minus: 1 }} / {{ section.blocks.size }});{% else %}width: {{ block.settings.banner_width }}%; max-width: {{ block.settings.banner_width }}%;{% endif %}">
            <div class="{% if block.settings.video != blank %}banner_video {% endif %}global-media-settings color-{{ block.settings.color_scheme }} gradient{% unless section.settings.image_height == 'adapt' %} banner__media{% endunless %} media{% if block.settings.image == blank and block.settings.video == blank %} placeholder{% endif %}{% if block.settings.image_behavior != 'none' %} animate--{{ block.settings.image_behavior }}{% endif %}" {% if section.settings.image_height == 'adapt' and block.settings.image != blank %} style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"{% endif %}>
              {%- if block.settings.video != blank -%}
                
                  {% capture video_html %}
                    {{ block.settings.video | video_tag: 
                        image_size: '1100x',
                        loop: false,
                        controls: false,
                        autoplay: true,
                        preload: true,
                        muted: true
                    }}
                  {% endcapture %}

                  {% if video_html contains 'loading="lazy"' %}
                    {{ video_html }}
                  {% else %}
                    {{ video_html | replace: '<img ', '<img loading="lazy" alt=""' }}
                  {% endif %}
                  <track kind="captions" srclang="en" src="" />
              {% else %} 
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    assign image_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                    assign sizes = full_width
                  -%}
                  {{
                   block.settings.image
                   | image_url: width: 3840
                   | image_tag:
                   loading: 'lazy',
                   width: block.settings.image.width,
                   height: image_height,
                   sizes: sizes,
                   widths: widths }}
                {% else %}
                  {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
                  {%- if placeholder_slide == 1 -%}
                    {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- else -%}
                    {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                {%- endif -%}
              {% endif %}
              
              {%- if block.settings.button_label_1 == blank and block.settings.button_link_1 != blank -%}
                <a class="full-image-link" href="{{ block.settings.button_link_1 }}" aria-label="{{ 'accessibility.full_link' | t }}"></a>
              {%- endif -%}
              {% if block.settings.heading == blank and block.settings.subheading == blank and block.settings.text == blank and  block.settings.button_label_1 == blank %}
                {% if block.settings.banner_offer_text != blank %}
                  <div class="banner-offer-marquee">
                    <div class="banner-offer-track offer_text_position-{{ block.settings.offer_text_position }}">
                      {% for i in (1..5) %}
                        <span>{{ block.settings.banner_offer_text }}</span>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}
              {% endif %}
              <div class="banner__content banner__content--{{ block.settings.desktop_content_position }} page-width {% if block.settings.show_text_box == false %} banner--desktop-transparent{% endif %}">
                <div class="{% unless block.settings.subheading == blank and block.settings.heading == blank and block.settings.button_label_1 == blank %} banner__box{% endunless %} container-{{ block.id }} content-container color-{{ block.settings.color_scheme }} gradient">
                  {% if block.settings.subheading != blank %}
                    <div class="banner__subheading offer_pills {% if block.settings.mini_heading_style == 'button' %}offer_pills_button {% elsif block.settings.mini_heading_style == 'outline' %}offer_pills_outline {% else block.settings.mini_heading_style == 'link' %}offer_pills_link {% endif %}rte">
                      {{ block.settings.subheading }} 
                    </div>
                  {% endif %}
                  {% if block.settings.heading != blank %}
                    <h3 class="banner__heading inline-richtext {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                      {{ block.settings.heading }}
                    </h3>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                      {{ block.settings.text }}
                    </div>
                  {% endif %}
                  {%- if block.settings.button_label_1 != blank -%}
                    <div class="banner__buttons{% if block.settings.button_label_1 != blank %} banner__buttons--multiple{% endif %}" {{ block.shopify_attributes }}>
                      {%- if block.settings.button_label_1 != blank -%}
                        <a
                          {% if block.settings.button_link_1 == blank %}
                          role="link" aria-disabled="true"
                          {% else %}
                          href="{{ block.settings.button_link_1 }}"
                          {% endif %}
                          {% if block.settings.link_window %} target="_blank" {% endif %}
                          class="{% if block.settings.view_all_style == 'link' %} link link underlined-link{% elsif block.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}">
                          {{- block.settings.button_label_1 | escape -}}
                        </a>
                      {%- endif -%}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>

          {%- style -%}
            .wbimgbnrblock #Slide-{{ section.id }}-{{ forloop.index }} .media::after {
              opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
            }
            .section-image-banner .section-{{ section.id }} .banner__box.container-{{ block.id }} {
              background-color: rgba(var(--color-background),{{ block.settings.container_overlay_opacity | divided_by: 100.0 }});
              border-radius: var(--text-boxes-radius);
            }
            .section-image-banner .section-{{ section.id }} .banner--desktop-transparent .banner__box.container-{{ block.id }}{
              background: transparent;
              border: none;
              border-radius: 0;
              box-shadow: none;
            }
          {%- endstyle -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section section-image-banner",
  "max_blocks": 8,
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "t:sections.video.settings.full_width.label"
    },
    {
      "type": "checkbox",
      "id": "enable_sidespace",
      "default": true,
      "label": "Enable side space"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Image banner",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h0",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "t:sections.featured-collection.settings.description_style.label",
      "options": [
        {
          "value": "body",
          "label": "t:sections.featured-collection.settings.description_style.options__1.label"
        },
        {
          "value": "subtitle",
          "label": "t:sections.featured-collection.settings.description_style.options__2.label"
        },
        {
          "value": "uppercase",
          "label": "t:sections.featured-collection.settings.description_style.options__3.label"
        }
      ],
      "default": "body"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.collapsible_content.settings.heading_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.image-with-text.settings.height.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.image-banner.settings.image_height.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.image-banner.settings.image_height.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.image-banner.settings.image_height.options__4.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.image-banner.settings.image_height.label",
      "info": "t:sections.image-banner.settings.image_height.info"
    },
    {
      "type": "checkbox",
      "id": "show_gap",
      "default": true,
      "label": "t:sections.image-banner.settings.show_gap.label"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "banner_with_text",
      "name": "t:sections.image-banner.presets.name",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.video.settings.video.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.image-banner.settings.image.label"
        },
        {
          "type": "range",
          "id": "image_overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 10,
          "unit": "%",
          "label": "t:sections.image-banner.blocks.heading.settings.image_overlay_opacity.label",
          "default": 40
        },
        {
          "type": "range",
          "id": "banner_width",
          "min": 25,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "t:sections.image-banner.blocks.heading.settings.banner_width.label",
          "default": 33
        },
        {
          "type": "richtext",
          "id": "banner_offer_text",
          "label": "Offer text",
          "visible_if": "{{ block.settings.heading == blank and block.settings.subheading == blank and block.settings.text == blank and  block.settings.button_label_1 == blank }}"
        },
        {
          "type": "select",
          "id": "offer_text_position",
          "options": [
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "middle",
              "label": "Middle"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            }
          ],
          "default": "middle",
          "label": "Offer text position",
          "visible_if": "{{ block.settings.heading == blank and block.settings.subheading == blank and block.settings.text == blank and  block.settings.button_label_1 == blank }}"
        },
        {
          "type": "richtext",
          "id": "subheading",
          "default": "<p>Image banner</p>",
          "label": "t:sections.image-banner.blocks.heading.settings.subheading.label"
        },
        {
          "type": "select",
          "id": "mini_heading_style",
          "options": [
            {
              "value": "button",
              "label": "t:sections.all.mini_heading_style.options__1.label"
            },
            {
              "value": "outline",
              "label": "t:sections.all.mini_heading_style.options__2.label"
            },
            {
              "value": "link",
              "label": "t:sections.all.mini_heading_style.options__3.label"
            }
          ],
          "default": "link",
          "label": "t:sections.all.mini_heading_style.label"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Image banner",
          "label": "t:sections.image-banner.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Give customers details about the banner image(s) or content on the template.</p>",
          "label": "t:sections.image-banner.blocks.text.settings.text.label"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "body",
              "label": "t:sections.image-banner.blocks.text.settings.text_style.options__1.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.image-banner.blocks.text.settings.text_style.options__2.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.image-banner.blocks.text.settings.text_style.options__3.label"
            }
          ],
          "default": "body",
          "label": "t:sections.image-banner.blocks.text.settings.text_style.label"
        },
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Button label",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_label_1.label",
          "info": "t:sections.image-banner.blocks.buttons.settings.button_label_1.info"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_link_1.label"
        },
        {
          "type": "checkbox",
          "id": "link_window",
          "label": "t:sections.slideshow.blocks.slide.settings.link_window.label",
          "default": true
        },
        {
          "type": "select",
          "id": "view_all_style",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_style_secondary_1.label",
          "options": [
            {
              "value": "link",
              "label": "t:sections.featured-collection.settings.view_all_style.options__1.label"
            },
            {
              "value": "outline",
              "label": "t:sections.featured-collection.settings.view_all_style.options__2.label"
            },
            {
              "value": "solid",
              "label": "t:sections.featured-collection.settings.view_all_style.options__3.label"
            }
          ],
          "default": "solid"
        },
        {
          "type": "checkbox",
          "id": "show_text_box",
          "default": true,
          "label": "t:sections.image-banner.settings.show_text_box.label"
        },
        {
          "type": "range",
          "id": "container_overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 10,
          "unit": "%",
          "label": "t:sections.image-banner.blocks.heading.settings.container_overlay_opacity.label",
          "default": 40
        },
        {
          "type": "select",
          "id": "desktop_content_position",
          "options": [
            {
              "value": "top-left",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__1.label"
            },
            {
              "value": "top-center",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__2.label"
            },
            {
              "value": "top-right",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__3.label"
            },
            {
              "value": "middle-left",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__4.label"
            },
            {
              "value": "middle-center",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__5.label"
            },
            {
              "value": "middle-right",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__6.label"
            },
            {
              "value": "bottom-left",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__7.label"
            },
            {
              "value": "bottom-center",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__8.label"
            },
            {
              "value": "bottom-right",
              "label": "t:sections.image-banner.settings.desktop_content_position.options__9.label"
            }
          ],
          "default": "middle-center",
          "label": "t:sections.image-banner.settings.desktop_content_position.label"
        },
        {
          "type": "select",
          "id": "desktop_content_alignment",
          "options": [
            {
              "value": "left",
              "label": "t:sections.image-banner.settings.desktop_content_alignment.options__1.label"
            },
            {
              "value": "center",
              "label": "t:sections.image-banner.settings.desktop_content_alignment.options__2.label"
            },
            {
              "value": "right",
              "label": "t:sections.image-banner.settings.desktop_content_alignment.options__3.label"
            }
          ],
          "default": "center",
          "label": "t:sections.image-banner.settings.desktop_content_alignment.label"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "background-1"
        },
        {
          "type": "header",
          "content": "t:sections.all.animation.content"
        },
        {
          "type": "select",
          "id": "image_behavior",
          "options": [
            {
              "value": "none",
              "label": "t:sections.all.animation.image_behavior.options__1.label"
            },
            {
              "value": "ambient",
              "label": "t:sections.all.animation.image_behavior.options__2.label"
            }
          ],
          "default": "none",
          "label": "t:sections.all.animation.image_behavior.label"
        },
        {
          "type": "header",
          "content": "t:sections.multirow.settings.header_mobile.content"
        },
        {
          "type": "select",
          "id": "mobile_content_alignment",
          "options": [
            {
              "value": "left",
              "label": "t:sections.multirow.settings.mobile_content_alignment.options__1.label"
            },
            {
              "value": "center",
              "label": "t:sections.multirow.settings.mobile_content_alignment.options__2.label"
            },
            {
              "value": "right",
              "label": "t:sections.multirow.settings.mobile_content_alignment.options__3.label"
            }
          ],
          "default": "center",
          "label": "t:sections.multirow.settings.mobile_content_alignment.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-banner.presets.name",
      "blocks": [
        {
          "type": "banner_with_text"
        },
        {
          "type": "banner_with_text"
