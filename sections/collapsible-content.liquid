      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_part",
      "default": false,
      "label": "Enable sticky image/heading on desktop",
      "info": "For the heading, this feature works \"Heading position\" is next to collapse."
    },
    {
