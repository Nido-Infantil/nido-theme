<link rel="preload" as="style" href="{{ 'component-accordion.css' | asset_url }}">
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}

{%- style -%}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
@media screen and (max-width: 991px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
}
{%- endstyle -%}
{% if section.settings.caption != blank or section.settings.heading != blank or section.settings.description != blank or section.settings.button_label_1 != blank or section.settings.image != blank or section.blocks.size > 0 %}
<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding {{ section.settings.enable_sticky_part }} {% if section.settings.enable_sticky_part == true %} sticky_part{% endif %}">
  <div class="{% if section.settings.layout == 'none' %}collapsible-content-wrapper-narrow{% endif %} collapsible-content collapsible-{{ section.settings.layout }}-layout isolate{% if section.settings.layout == 'section' or section.settings.layout == 'row' %} page-width{% elsif section.settings.layout == 'none' %} content-container content-container--full-width{% endif %}">
    <div class="collapsible-content__wrapper{% if section.settings.heading_position == 'coll_next' %} faq_coll_next{% endif %}{% if section.settings.layout == 'section' %} secondary-bg-spacing{% endif %}{% if section.settings.secondary_background %} background-secimg{% else %} gradient{% endif %} color-{{ section.settings.color_scheme }} "> 
      {% if section.settings.caption != blank or section.settings.heading != blank or section.settings.description != blank or section.settings.button_label_1 != blank %}
        <div class="{% if section.settings.heading_alignment == 'center' or section.settings.heading_position == 'coll_left' %}heading-top {% endif %}collapsible-content__header {{ section.settings.heading_alignment }}">
        {% if section.settings.enable_sticky_part == true and section.settings.heading_position == 'coll_next' %}<div class="sticky_heading"> {% endif %}
          <div class="heading inline-richtext {{ section.settings.heading_alignment }}">
            {%- if section.settings.caption != blank -%}
              <p class="caption-with-letter-spacing offer_pills {% if section.settings.mini_heading_style == 'button' %}offer_pills_button {% elsif section.settings.mini_heading_style == 'outline' %}offer_pills_outline {% else section.settings.mini_heading_style == 'link' %}offer_pills_link {% endif %}">{{ section.settings.caption | escape }}</p>
            {% endif %}
            {%- if section.settings.heading != blank -%}
              <h2 class="collapsible-content__heading inline-richtext {{ section.settings.heading_size }}">
                {{ section.settings.heading }}
              </h2>
            {%- else -%}
              <h2 class="visually-hidden">{{ 'accessibility.collapsible_content_title' | t }}</h2>
            {% endif %}
            {%- if section.settings.description != blank -%}
                {{ section.settings.description }}
            {%- endif -%}
          </div>
          {%- if section.settings.button_label_1 != blank -%}
          <div class="wb_button_combo {% unless section.settings.button_label_1 %}bcombo_auto{% endunless %} {% if section.settings.heading_position == 'coll_next' %} justify-content-{{ section.settings.heading_alignment }}{% endif %}">
              <div class="banner__buttons{% if section.settings.button_label_1 != blank %} banner__buttons--multiple{% endif %}">
                {%- if section.settings.button_label_1 != blank -%}
                  <a
                    {% if section.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                    {% else %}
                    href="{{ section.settings.button_link_1 }}"
                    {% endif %}
                    class="{% if section.settings.view_all_style == 'link' %} link link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}">
                    {{- section.settings.button_label_1 | escape -}}
                  </a>
                {%- endif -%}
              </div>
            </div>
          {% endif %}
        {% if section.settings.enable_sticky_part == true and section.settings.heading_position == 'coll_next' %}</div> {% endif %}
        </div>
      {% endif %}
      {% if section.settings.image != blank or section.blocks.size > 0 %}
        <div class="grid{% if section.settings.image != blank and section.blocks.size > 0 %} grid--2-col-tablet{% else %} grid--1-col{% endif %} grid--1-col-tablet-down collapsible-content__grid{% if section.settings.desktop_layout == 'image_second' %} collapsible-content__grid--reverse{% endif %}">
          {%- if section.settings.image != blank -%}
            <div class="grid__item collapsible-content__grid-item collapsible_media">
              <div
                class="collapsible-content__media collapsible-content__media--{{ section.settings.image_ratio }} media global-media-settings gradient"
                {% if section.settings.image_ratio == 'adapt' %}
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- capture sizes -%}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                  (min-width: 768px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                {%- endcapture -%}
                {{
                  section.settings.image
                  | image_url: width: 1500
                  | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1250, 1500'
                }}
              </div>
            </div>
          {% endif %}
          {% if section.blocks.size > 0 %}
            <webi-collapse class="grid__item"> 
              {%- for block in section.blocks -%}
                <div class="accordion{% if section.settings.layout == 'row' %} content-container color-{{ section.settings.container_color_scheme }} gradient{% endif %}" {{ block.shopify_attributes }}>
                  <div id="Detailswebi-{{ block.id }}-{{ section.id }}">
                    <summary id="Summary-{{ block.id }}-{{ section.id }}" data-toggle="collapse" aria-expanded="false" class="toggle collapsed">
                      {% if block.settings.custom_image != blank %}
                        {%- assign image_alt = block.settings.custom_image.alt | escape -%}
                        {{
                          block.settings.custom_image
                          | image_url: width: 20, height: 20
                          | image_tag:
                            loading: 'lazy',
                            width: 20,
                            height: 20,
                            alt: image_alt,
                            class: 'icon-accordion'
                        }}
                      {% else %}
                        {% render 'icon-accordion', icon: block.settings.icon %}
                      {% endif %}
                      <h3 class="accordion__title inline-richtext h4">
                        {{ block.settings.heading | default: block.settings.page.title }}
                      </h3>
                      {% comment %} {% render 'icon-caret' %} {% endcomment %}
                    </summary>
                    {% if block.settings.row_content != blank or block.settings.page.content != blank or block.settings.content_image != blank %}
                      <div class="collapse wbcollapse_cont">
                        <div class="accordion__content rte" id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}" role="region" aria-labelledby="Summary-{{ block.id }}-{{ section.id }}">
                          {{ block.settings.row_content }}
                          {{ block.settings.page.content }}
                          {% if block.settings.content_image != blank %}
                            <img srcset="
                              {%- if block.settings.content_image.image.width >= 165 -%}{{ block.settings.content_image | image_url: width: 165 }} 165w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 360 -%}{{ block.settings.content_image | image_url: width: 360 }} 360w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 535 -%}{{ block.settings.content_image | image_url: width: 535 }} 535w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 750 -%}{{ block.settings.content_image | image_url: width: 750 }} 750w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 1070 -%}{{ block.settings.content_image | image_url: width: 1070 }} 1070w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 1500 -%}{{ block.settings.content_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 1800 -%}{{ block.settings.content_image | image_url: width: 2000 }} 1500w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 2200 -%}{{ block.settings.content_image | image_url: width: 2200 }} 2200w,{%- endif -%}
                              {%- if block.settings.content_image.width >= 3000 -%}{{ block.settings.content_image | image_url: width: 3000 }} 3000w,{%- endif -%} {{ block.settings.content_image | image_url }} {{ block.settings.content_image.width }}w"
                            src="{{ block.settings.content_image | image_url: width: 2000 }}"
                            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 10 | divided_by: 2 }}px, (min-width: 768px) calc(70vw - 10px), calc(50vw - 10px)"
                            alt="{{ block.settings.content_image.alt | escape }}"
                            width="{{ block.settings.content_image.width }}"
                            height="{{ block.settings.content_image.height }}"
                            loading="lazy">
                          {% endif %}
                        </div>
                      </div>
                    {% endif %}
                  </div>
                </div>
              {%- endfor -%}
            </webi-collapse>
          {% endif %}
        </div>
      {% endif %}
    </div> 
  </div>
</div>
{% endif %}
{% schema %}
{
