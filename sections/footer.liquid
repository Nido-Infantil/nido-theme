{% comment %}theme-check-disable UndefinedObject{% endcomment %}
<link rel="preload" as="style" href="{{ 'section-footer.css' | asset_url }}">
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'component-newsletter.css' | asset_url }}">
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'component-list-menu.css' | asset_url }}">
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'component-list-payment.css' | asset_url }}">
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'component-list-social.css' | asset_url }}">
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
    <link rel="preload" as="style" href="{{ 'component-localization-form.css' | asset_url }}">
  {{ 'component-localization-form.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- style -%}
    .footer {
        margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    @media screen and (max-width: 991px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
      }
    }
    @media screen and (min-width: 768px) {
        .footer {
            margin-top: {{ section.settings.margin_top }}px;
        }
    }
{%- endstyle -%}
<div class="footer section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
    {%- liquid
        assign has_social_icons = true
        if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
            assign has_social_icons = false
        endif

        if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.enable_follow_on_shop == false
            assign only_empty_brand = true
        endif

        assign has_newsletter_block = false
        assign has_localization_menu_block = false
        assign footer_content_blocks_count = 0
        for block in section.blocks
            if block.type == 'localization_menu'
                assign has_localization_menu_block = true
            else
                assign footer_content_blocks_count = footer_content_blocks_count | plus: 1
                if block.type == 'newsletter'
                    assign has_newsletter_block = true
                endif
            endif
        endfor
    -%}
    {%- if footer_content_blocks_count > 0
    or section.settings.show_social
    or section.settings.enable_follow_on_shop
    -%}
      {% if footer_content_blocks_count > 0 %}
        {%- unless only_empty_brand -%}
            <div class="footer__content-top page-width">
                {%- if footer_content_blocks_count > 0 -%}
                    {%- liquid
                        if footer_content_blocks_count == 9
                            assign footer_grid_class = 'grid--3-col-tablet'
                        elsif footer_content_blocks_count > 6
                            assign footer_grid_class = 'grid--4-col-desktop'
                        elsif footer_content_blocks_count > 4
                            assign footer_grid_class = 'grid--3-col-tablet'
                        endif
                    -%}
                    <webi-collapse class="footer__blocks-wrapper grid grid--1-col-tablet-down grid--{{ footer_content_blocks_count }}-col-desktop grid--2-col grid--4-col-tablet{% if has_newsletter_block %} footer__blocks-wrapper--five-col{% endif %} {{ footer_grid_class }}">
                        {%- for block in section.blocks -%}
                          {%- unless block.type == 'localization_menu' -%}
                            <div class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}{% if block.type == 'newsletter' %} footer-block--newsletter-item{% endif %}"
                                    {{ block.shopify_attributes }}>
                                {%- if block.type == 'newsletter' and settings.logo != blank -%}
                                    {%- assign footer_newsletter_logo_alt = settings.logo.alt | default: shop.name | escape -%}
                                    {%- assign footer_newsletter_logo_width = settings.logo_width | at_most: 180 -%}
                                    {%- assign footer_newsletter_logo_height = footer_newsletter_logo_width | divided_by: settings.logo.aspect_ratio | round -%}
                                    <a href="{{ routes.root_url }}" class="footer-newsletter__logo-link">
                                        {{
                                            settings.logo
                                            | image_url: width: 360
                                            | image_tag:
                                                loading: 'lazy',
                                                width: footer_newsletter_logo_width,
                                                height: footer_newsletter_logo_height,
                                                alt: footer_newsletter_logo_alt,
                                                class: 'footer-newsletter__logo img-fluid'
                                        }}
                                    </a>
                                {%- endif -%}
                                {%- if block.settings.heading != blank -%}
                                    <h2 class="footer-block__heading inline-richtext {% if block.settings.footer_logo != blank %}footer-logo{% endif %} h6 rte" id="wb-{{ block.settings.heading | camelcase }}">{{- block.settings.heading -}}</h2>
                                {%- endif -%}
                                {%- case block.type -%}
                                    {%- when '@app' -%}
                                        {% render block %}
                                    {%- when 'text' -%}
                                        <div class="footer-block__details-content footer-collapse collapse rte {{ block.settings.description_style }}">
                                            {{ block.settings.subtext }}
                                        </div>
                                    {%- when 'link_list' -%}
                                        {%- if block.settings.menu != blank -%}
                                            <ul class="footer-block__details-content footer-collapse collapse list-unstyled">
                                                {%- for link in block.settings.menu.links -%}
                                                    <li><a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}">
                                                            {{ link.title }}
                                                        </a>
                                                    </li>
                                                {%- endfor -%}
                                            </ul>
                                        {%- endif -%}
                                    {%- when 'brand_information' -%}
                                        <div class="wbfootcont {% if block.settings.footer_logo == blank %} collapse footer-collapse {% endif %} {% if section.blocks.size == 1 %} one-block-design {% endif %}">
                                            {%- if block.settings.footer_logo != blank -%}
                                                {%- assign logo_alt = block.settings.footer_logo.alt | default: shop.name | escape -%}
                                                {%- assign logo_height = block.settings.footer-logo_width | divided_by: block.settings.footer_logo.aspect_ratio | round -%}
                                                <a href="{{ routes.root_url }}" class="flog" style="max-width: {{ block.settings.footer-logo_width }}px;object-fit: contain">
                                                  {{
                                                    block.settings.footer_logo
                                                    | image_url: width: 200
                                                    | image_tag:
                                                      loading: 'lazy',
                                                      width: block.settings.footer_logo.width,
                                                      height: logo_height,
                                                      alt: logo_alt,
                                                      class: 'footer-logo img-fluid'
                                                  }}
                                                </a>
                                            {%- endif -%}
                                            {%- if block.settings.contsubtext != blank -%}
                                                <div class="{{ block.settings.description_style }}">
                                                    {{ block.settings.contsubtext }}
                                                </div>
                                            {%- endif -%}
                                            <ul>
                                                {%- if block.settings.footer_contact_no != blank -%}
                                                    {%- liquid
                                                        assign whatsapp_number = block.settings.footer_contact_no | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: '+', '' | replace: '.', ''
                                                        if whatsapp_number.size <= 11
                                                            assign whatsapp_number = whatsapp_number | prepend: '55'
                                                        endif
                                                    -%}
                                                    <li>{% render 'icon-whatsapp' %} <a class="rte" href="https://wa.me/{{ whatsapp_number }}" target="_blank" rel="noopener">{{ block.settings.footer_contact_no }}</a>
                                                    </li>
                                                {%- endif -%}
                                                {%- if block.settings.footer_contact_id != blank -%}
                                                    <li>{% render 'icon-email' %} <span class="rte">{{ block.settings.footer_contact_id }}</span>
                                                    </li>
                                                {%- endif -%}
                                                {%- if block.settings.footer_address != blank -%}
                                                    <li>{% render 'icon-faddress' %} <span>{{ block.settings.footer_address }}</span>
                                                    </li>
                                                {%- endif -%}
                                            </ul>
                                        </div>
                                    {%- when 'image' -%}
                                        <div class="footer-block__details-content collapse footer-collapse footer-block-image {{ block.settings.alignment }}">
                                            {%- if block.settings.image != blank -%}
                                                {%- assign image_size_2x = block.settings.image__width | times: 2 | at_most: 5760 -%}
                                                <div class="footer-block__image-wrapper global-media-settings" style="max-width: min(100%, {{ block.settings.image__width }}px);">
                                                    <img srcset="{{ block.settings.image | image_url: width: block.settings.image__width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                                                        src="{{ block.settings.image | image_url: width: 760 }}"
                                                        alt="{{ block.settings.image.alt | escape }}"
                                                        loading="lazy"
                                                        width="{{ block.settings.image.width }}"
                                                        height="{{ block.settings.image.height }}">
                                                </div>
                                            {%- else -%}
                                            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                                            {%- endif -%}
                                        </div>
                                    {%- when 'newsletter' -%}
                                        <div class="footer-block--newsletter footer-collapse collapse">
                                            <div class="footer-block__newsletter">
                                                <div class="wb_news_content rte {{ block.settings.description_style }}">
                                                    {{ block.settings.news_subtext }}
                                                </div>
                                                {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                                                    <input type="hidden" name="contact[tags]" value="newsletter">
                                                    <div class="newsletter-form__field-wrapper {% if section.blocks.size > 4 %} news-block-design {% endif %}">
                                                        <div class="field">
                                                            <input
                                                                    id="NewsletterForm--{{ section.id }}"
                                                                    type="email"
                                                                    pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$"
                                                                    name="contact[email]"
                                                                    class="field__input"
                                                                    value="{{ form.email }}"
                                                                    aria-required="true"
                                                                    autocapitalize="off"
                                                                    autocomplete="email"
                                                                    {% if form.errors %}
                                                                        autofocus
                                                                        aria-invalid="true"
                                                                        aria-describedby="ContactFooter-error"
                                                                    {% elsif form.posted_successfully? %}
                                                                        aria-describedby="ContactFooter-success"
                                                                    {% endif %}
                                                                    placeholder="{{ 'newsletter.label' | t }}"
                                                                    required
                                                            >
                                                            <label class="field__label"
                                                                   for="NewsletterForm--{{ section.id }}">
                                                                {{ 'newsletter.label' | t }}
                                                            </label>
                                                         </div>
                                                            <button
                                                                    type="submit"
                                                                    class="newsletter-form__button field__button button button--primary"
                                                                    name="commit"
                                                                    id="Subscribe"
                                                                    aria-label="{{ 'newsletter.button_label' | t }}"
                                                            >{{ 'newsletter.button_label' | t }}</button>
                                                    </div>
                                                    {%- if form.errors -%}
                                                      <small class="newsletter-form__message form__message"
                                                             id="ContactFooter-error">
                                                          {%- render 'icon-error' -%}
                                                          {{- form.errors.translated_fields.email | capitalize }}
                                                          {{ form.errors.messages.email -}}
                                                      </small>
                                                  {%- endif -%}
                                                    {%- if form.posted_successfully? -%}
                                                        <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>
                                                          {% render 'icon-success' -%}
                                                          {{- 'newsletter.success' | t }}
                                                        </h3>
                                                    {%- endif -%}
                                                {%- endform -%}
                                            </div>
                                        </div>
                                {%- endcase -%}
                            </div>
                          {%- endunless -%}
                        {%- endfor -%}
                    </webi-collapse>
                {%- endif -%}
            </div>
        {%- endunless -%}
      {% endif %}
    {%- endif -%}
    {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
        <div class="footer__follow-on-shop">
            {% comment %} TODO: enable theme-check once `login_button` is accepted as valid filter {% endcomment %}
            {% # theme-check-disable %}
            {{ shop | login_button: action: 'follow' }}
            {% # theme-check-enable %}
        </div>
    {%- endif -%}
    {% if section.settings.enable_language_selector or section.settings.enable_country_selector or section.settings.payment_enable or section.settings.show_social or has_localization_menu_block %}
      <div class="footer__content-bottom">
        <div class="footer__content-bottom-wrapper page-width">
            {% if section.settings.enable_country_selector or section.settings.enable_language_selector or has_localization_menu_block %}
                <div class="footer__column footer__localization isolate">
                    {%- for block in section.blocks -%}
                        {%- if block.type == 'localization_menu' -%}
                            <div class="footer-localization-menu" {{ block.shopify_attributes }}>
                                {%- if block.settings.heading != blank -%}
                                    <h3>{{ block.settings.heading }}</h3>
                                {%- endif -%}
                                {%- if block.settings.menu != blank -%}
                                    <ul class="footer-localization-menu__list list-unstyled">
                                        {%- for link in block.settings.menu.links -%}
                                            <li>
                                                <a href="{{ link.url }}" class="link link--text{% if link.active %} list-menu__item--active{% endif %}">
                                                    {{ link.title }}
                                                </a>
                                            </li>
                                        {%- endfor -%}
                                    </ul>
                                {%- endif -%}
                            </div>
                        {%- endif -%}
                    {%- endfor -%}
                    {% if section.settings.lang_heading != blank -%}
                        <h3>{{ section.settings.lang_heading }}</h3>
                    {% endif %}
                    <div>
                        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                            <noscript>
                                {%- form 'localization', id: 'FooterLanguageFormNoScript', class: 'localization-form' -%}
                                    <div class="localization-form__select">
                                        <select
                                                class="localization-selector link"
                                                name="locale_code"
                                                aria-labelledby="FooterLanguageLabelNoScript"
                                        >
                                            {%- for language in localization.available_languages -%}
                                                <option
                                                        value="{{ language.iso_code }}"
                                                        lang="{{ language.iso_code }}"
                                                        {%- if language.iso_code == localization.language.iso_code %}
                                                            selected
                                                        {% endif %}
                                                >
                                                    {{ language.endonym_name | capitalize }}
                                                </option>
                                            {%- endfor -%}
                                        </select>
                                        {% render 'icon-caret' %}
                                    </div>
                                    <button class="button button--tertiary">{{ 'localization.update_language' | t }}</button>
                                {%- endform -%}
                            </noscript>

                            <localization-form>
                                {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                                    <div class="no-js-hidden">
                                        {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                                    </div>
                                {%- endform -%}
                            </localization-form>
                        {%- endif -%}
                        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                            <noscript>
                                {%- form 'localization', id: 'FooterCountryFormNoScript', class: 'localization-form' -%}
                                    <div class="localization-form__select">
                                        <select
                                                class="localization-selector link"
                                                name="country_code"
                                        >
                                            {%- for country in localization.available_countries -%}
                                                <option
                                                        value="{{ country.iso_code }}"
                                                        {%- if country.iso_code == localization.country.iso_code %}
                                                            selected
                                                        {% endif %}
                                                >{{ country.currency.iso_code }}
                                                    {{ country.currency.symbol }}
                                                </option>
                                            {%- endfor -%}
                                        </select>
                                        {% render 'icon-caret' %}
                                    </div>
                                    <button class="button button--tertiary">{{ 'localization.update_country' | t }}</button>
                                {%- endform -%}
                            </noscript>
                            <localization-form>
                                {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                                    <div class="no-js-hidden">
                                        {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                                    </div>
                                {%- endform -%}
                            </localization-form>
                        {%- endif -%}
                    </div>
            </div>
            {% endif %}
            {%- if section.settings.payment_enable -%}
              <div class="footer__column footer__column--info">
                <div class="footer__payment">
                    {% if section.settings.pay_heading != blank -%}
                        <h3>{{ section.settings.pay_heading }}</h3>
                    {% endif %}
                  <ul class="list list-payment" role="list">
                      {%- for type in shop.enabled_payment_types -%}
                        <li class="list-payment__item">
                          {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                        </li>
                      {%- endfor -%}
                  </ul>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.show_social and has_social_icons -%}
                <div class="footer__column footer--social">
                    <div class="text-left">
                    {% if section.settings.social_heading != blank -%}
                        <h3>{{ section.settings.social_heading }}</h3>
                    {% endif %}
                    {%- render 'social-icons' -%}
                    </div>
                </div>
            {%- endif -%}
        </div>
      </div>
    {% endif%}
    {% if section.settings.show_copyright or section.settings.show_policy and shop.policies != blank %}
        <div class="footer__content-bottom-wrapper footer_copyright_wrapper{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">

        <div class="footer__copyright caption">
          {% comment %} {%- if section.settings.show_copyright -%}
            <small class="copyright__content"
            > 
            {% render 'icon-copyright' %}
            
            {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
            </small>
            <small class="copyright__content">{{ powered_by_link }}</small>
          {%- endif -%}
          {%- if section.settings.show_policy -%}
            <ul class="policies list-unstyled">
                {%- for policy in shop.policies -%}
                    {%- if policy != blank -%}
                        <li>
                          <small class="copyright__content"><a href="{{ policy.url }}">{{ policy.title }}</a></small>
                        </li>
                    {%- endif -%}
                {%- endfor -%}
            </ul>
          {%- endif -%} {% endcomment %}
          © 2026 Zarix Energia - Zarix Solucoes Inteligentes LTDA | Todos os direitos reservados CNPJ: 53.519.375/0001-29 Endereco: PC Jose Dias Aranha, 138, Parque Industrial, Tuiuti / SP CEP: 13.309-639
        </div>
    </div>
    {% endif %}
    {%- if section.settings.scroll-to-top -%}
        <button class="button scrollhide" id="scroll" onclick="scrollToTop()"
                title="{{ 'wbcustomlabel.wballtext.scrolltop' | t }}">{% render 'icon-double-arrow-up' %}</button>
    {%- endif -%}
</div>

{%- if section.settings.scroll-to-top -%}
<script>
window.onscroll = () => {
  toggleTopButton();
}
function scrollToTop(){
  window.scrollTo({top: 0, behavior: 'smooth'});
}
function toggleTopButton() {
  if (document.body.scrollTop > 600 ||
      document.documentElement.scrollTop > 600) {
    document.getElementById('scroll').classList.remove('scrollhide');
  } else {
    document.getElementById('scroll').classList.add('scrollhide');
  }
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.footer.name",
  "tag": "footer",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "localization_menu",
      "name": "Menu inferior",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Links",
          "label": "Titulo"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu",
          "info": "Escolha o menu que aparece na coluna de localizacao do footer."
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "footer_logo",
          "label": "t:sections.footer.blocks.brand_information.settings.footer_logo.label"
        },
        {
          "type": "range",
          "id": "footer-logo_width",
          "label": "t:sections.footer.blocks.brand_information.settings.footer-logo_width.label",
          "max": 200,
          "min": 100,
          "unit": "px",
          "step": 10,
          "default": 150
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "t:sections.footer.blocks.brand_information.settings.heading.label",
          "default": "Contact us",
          "info": "t:sections.footer.blocks.brand_information.settings.heading.info"
        },
        {
          "type": "richtext",
          "id": "contsubtext",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        },
        {
          "type": "select",
          "id": "description_style",
          "label": "t:sections.all.description_style.label",
          "options": [
            {
              "value": "body",
              "label": "t:sections.all.description_style.options__1.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.all.description_style.options__2.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.description_style.options__3.label"
            }
          ],
          "default": "body"
        },
        {
          "type": "textarea",
          "id": "footer_address",
          "label": "t:sections.footer.blocks.brand_information.settings.footer_address.label",
          "default": "demo store United States."
        },
        {
          "type": "inline_richtext",
          "id": "footer_contact_no",
          "label": "t:sections.footer.blocks.brand_information.settings.footer_contact_no.label",
          "default": "0123-456-789"
        },
        {
          "type": "inline_richtext",
          "id": "footer_contact_id",
          "label": "t:sections.footer.blocks.brand_information.settings.footer_contact_id.label",
          "default": "demo@demo.com"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Share contact information, store details, and brand content with your customers.</p>",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        },
        {
          "type": "select",
          "id": "description_style",
          "label": "t:sections.all.description_style.label",
          "options": [
            {
