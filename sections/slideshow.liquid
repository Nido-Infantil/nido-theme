<link rel="preload" as="style" href="{{ 'section-image-banner.css' | asset_url }}">
{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'component-slider.css' | asset_url }}">
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
<link rel="preload" as="style" href="{{ 'component-slideshow.css' | asset_url }}">
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
    @media screen and (min-width: 768px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.mobile_image != blank -%}
  {%- style -%}
    @media screen and (max-width: 767px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before,
      #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.mobile_image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- else -%}
  {%- style -%}
    @media screen and (max-width: 767px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before,
      #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{%- style -%}
  .slidshow-section--{{ section.id }}.pagenation_align--left{
    justify-content: flex-start !important;
  } 
  .slidshow-section--{{ section.id }}.pagenation_align--right{
    justify-content: flex-end !important;
  } 
  .slidshow-section--{{ section.id }}.pagenation_align--center{
    justify-content: center !important;
  }
  .slide_out {
    width: 100%;
  }
  .wb_contrs.slider-buttons:not(.slide_out){
    position: absolute;
    bottom: 5px;
    left: 0;
    right: 0;
    z-index: 2;
  } 
  {% if section.settings.layout == 'grid' %}
    .slidshow-section--{{ section.id }} .wb_button_cover{
      margin: 5px 50px;
    }
    .slideshow__media.banner__media::after,
    .slideshow__slide .slideshow__media.media > img {
      border-radius: calc(var(--media-radius) - var(--media-border-width));
    }
    .slideshow__media .placeholder-svg {
      border-radius: var(--media-radius);
    }
    @media (max-width: 991px) {
      .slideshow__media.banner__media::after,
      .slideshow__slide .slideshow__media.media > img {
        border-radius: calc(var(--media-radius) * 1 / 2 - var(--media-border-width));
      }
      .slideshow__media .placeholder-svg {
        border-radius: calc(var(--media-radius) * 1 / 2);
      }
    }
  {% else %}
    .slidshow-section--{{ section.id }} .wb_button_cover{
      margin: 5px 10px;
    }
    .slideshow__media.banner__media::after,
    .slideshow__slide .slideshow__media.media > img,
    .slideshow__media.banner__media, .slideshow__media .placeholder-svg {
      border-radius: unset;
    }
  {% endif %}
  .slidshow-section--{{ section.id }} .wb_button_cover{
    display: flex;
    align-items: center;
    background: {{ section.settings.pagenation_background }};
    border-radius: {{ section.settings.pagenet_corner_radius }}px;
  }
  .slidshow-section--{{ section.id }} .slider-counter__link--active.slider-counter__link--numbers,.slidshow-section--{{ section.id }} .slider-button,.slidshow-section--{{ section.id }} .slider-counter__link--numbers:hover,.slidshow-section--{{ section.id }} .slider-counter,.slidshow-section--{{ section.id }}  .slider-counter__link--numbers,.slider-counter--pagination_text .slider-counter__link{
    color: {{ section.settings.pagenation_foreground }};
  }
  .slidshow-section--{{ section.id }} .slider-counter__link--active.slider-counter__link--dots .dot{
    background: {{ section.settings.pagenation_foreground }};
  }
  .slidshow-section--{{ section.id }} .slider-counter__link--dots .dot, .slidshow-section--{{ section.id }} .slider-counter__link--dots:not(.slider-counter__link--active):hover .dot{
    border:1px solid {{ section.settings.pagenation_foreground }};
  }
  .slidshow-section--{{ section.id }} .slideshow__autoplay path{
    fill: {{ section.settings.pagenation_foreground }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media(max-width:1024px){
    {% if section.settings.layout == 'grid' %}
      .slidshow-section--{{ section.id }} .wb_button_cover{
        margin: 5px 25px;
      }
    {% else %}
      .slidshow-section--{{ section.id }} .wb_button_cover{
        margin: 5px 10px;
      }
    {% endif %}
  }
{%- endstyle -%} 
<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding gradient">
  <slideshow-component class="cshift_top slider-mobile-gutter{% if section.settings.layout == 'grid' %} page-width{% endif %}{% if section.settings.show_text_below %} mobile-text-below{% endif %} image--banner" role="region" aria-roledescription="{{ 'sections.slideshow.carousel' | t }}" aria-label="{{ section.settings.accessibility_info | escape }}">
    {%- if section.settings.auto_rotate and section.blocks.size > 1 -%}
      <div class="{% if section.settings.arrow_position == 'slide_out' %}slide_out {% endif %} slideshow__controls slidshow-section--{{ section.id }} pagenation_align--{{ section.settings.slider_alignment }} slideshow__controls--top wb_contrs slider-buttons no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %} {% unless section.settings.pagination_width == 'outside_container' %} page-width out__spacing{% endunless %}">
        <div class="wb_button_cover">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
          <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' or section.settings.slider_visual == 'pagination_text' %} caption{% endif %}">
            {%- if section.settings.slider_visual == 'counter' -%}
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ section.blocks.size }}</span>
            {%- else -%}
              <div class="slideshow__control-wrapper">
                {%- for block in section.blocks -%}
                  <button
                    class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                    aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                    aria-controls="Slider-{{ section.id }}"
                  >
                    {%- if section.settings.slider_visual == 'numbers' -%}
                      {{ forloop.index -}}
                    {%- elsif section.settings.slider_visual == 'dots' -%}
                      <span class="dot"></span>
                    {%- elsif section.settings.slider_visual == 'pagination_text' and block.settings.pagination_text != blank -%}
                      {{ block.settings.pagination_text }}
                    {%- else -%}
                     {{ 'sections.slideshow.pagination_text' | t }}
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
          {%- if section.settings.auto_rotate -%}
            <button
              type="button"
              class="slideshow__autoplay slider-button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
              aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}">
              {%- render 'icon-pause' -%}
              {%- render 'icon-play' -%}
            </button>
          {%- endif -%}
        </div>
      </div>
      <noscript>
        <div class="slider-buttons">
          <div class="slider-counter">
            {%- for block in section.blocks -%}
              <a href="#Slide-{{ section.id }}-{{ forloop.index }}" class="slider-counter__link link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}">
                {{ forloop.index }}
              </a>
            {%- endfor -%}
          </div>
        </div>
      </noscript>
    {%- endif -%}


    <div class="slideshow banner banner--{{ section.settings.slide_height }} grid grid--1-col slider slider--everywhere{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}{% if section.blocks.first.settings.image == blank %} slideshow--placeholder{% endif %}" id="Slider-{{ section.id }}" aria-live="polite" aria-atomic="true" data-autoplay="{{ section.settings.auto_rotate }}" data-speed="{{ section.settings.change_slides_speed }}">
      {%- for block in section.blocks -%}
        
        <div class="{% if forloop.first %}hero-zoomout{% endif %} slideshow__slide grid__item grid--1-col slider__slide" id="Slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }} role="group" aria-roledescription="{{ 'sections.slideshow.slide' | t }}" aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}" >
          <div class="{% if forloop.first %}hero-image{% endif %} slideshow__media banner__media media{% if block.settings.image == blank %} placeholder{% endif %} {%- if block.settings.mobile_image != blank -%}  hidden-slider-image-mobile {%- endif -%}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
            {%- if block.settings.image -%}
              {%- liquid  
                assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                if section.settings.image_behavior == 'ambient'
                  assign sizes = '120vw'
                  assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
                else
                  assign sizes = '100vw'
                  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                endif
                assign fetch_priority = 'auto'
                    if section.index == 1
                assign fetch_priority = 'high'
                endif
              -%}
              {%- if forloop.first %}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths
                }}
              {%- endif -%}
            {%- else -%}
              {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
              {%- if placeholder_slide == 1 -%}
              {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- if block.settings.mobile_image -%}
            <div class="slideshow__media banner__media wbslide mobile hidden_desktop media{% if block.settings.mobile_image == blank %} placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
              {%- if block.settings.mobile_image -%}
                {%- liquid  
                  assign height = block.settings.mobile_image.width | divided_by: block.settings.mobile_image.aspect_ratio | round
                  if section.settings.image_behavior == 'ambient'
                    assign sizes = '120vw'
                    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
                  else
                    assign sizes = '100vw'
                    assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                  endif
                  assign fetch_priority = 'auto'
                    if section.index == 1
                      assign fetch_priority = 'high'
                  endif
                -%}
                  {%- if forloop.first %}
                    {{
                      block.settings.mobile_image
                      | image_url: width: 3840
                      | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                    }}
                  {%- else -%}
                    {{
                      block.settings.mobile_image
                      | image_url: width: 3840
                      | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths
                    }}
                  {%- endif -%}
              {%- else -%}
                {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
                {%- if placeholder_slide == 1 -%}
                  {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- else -%}
                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if block.settings.button_label == blank and block.settings.link != blank -%}
            <a class="full-image-link" href="{{ block.settings.link }}" aria-label="{{ 'accessibility.full_link' | t }}"></a>
          {%- endif -%}
          <div class="hero-content slideshow__text-wrapper banner__content banner__content--{{ block.settings.box_align }} page-width{% if block.settings.show_text_box == false %} banner--desktop-transparent{% endif %}">
           
              <div class="slideshow__text
              {% unless block.settings.heading == blank and block.settings.subheading == blank and block.settings.button_label == blank %} banner__box {% endunless %} content-container content-container--full-width-mobile color-{{ block.settings.color_scheme }} gradient slideshow__text--{{ block.settings.text_alignment }} slideshow__text-mobile--{{ block.settings.text_alignment_mobile }}">
              {%- if block.settings.subheading != blank or block.settings.offer__text != blank -%}
                <div class="banner__text{% if forloop.first %} hero-text delay-1{% endif %} offer__text--{{ block.settings.text_alignment }} offer__text-mobile--{{ block.settings.text_alignment_mobile }} rte description offer__text {% if block.settings.subheading == blank %}only_offer_text{% endif %}" {{ block.shopify_attributes }}>
                  {% if block.settings.offer__text != blank %}
                    <span class="offer_pills {% if block.settings.mini_heading_style == 'button' %}offer_pills_button {% elsif block.settings.mini_heading_style == 'outline' %}offer_pills_outline {% else block.settings.mini_heading_style == 'link' %}offer_pills_link {% endif %} rte">{{ block.settings.offer__text }}</span>
                  {% endif %}
                  
                  {{ block.settings.subheading }}
                </div>
              {%- endif -%}  
              {%- if block.settings.heading != blank -%}
                  <h2 class="{% if forloop.first %}hero-text {% endif %}banner__heading inline-richtext {{ block.settings.heading_size }}{% if block.settings.offer__text != blank %} top-spacing{% endif %}">
                    {{ block.settings.heading }}
                  </h2>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <div class="{% if forloop.first %}hero-text delay-1 {% endif %}banner__text rte description {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                    {{ block.settings.description }}
                  </div>
                {%- endif -%}
                
                <div class="{% if forloop.first %}hero-text delay-2 {% endif %}banner__buttons banner__button">
                  {%- if block.settings.button_label != blank -%}
                    <div class="banner__buttons">
                      <a
                        {% if block.settings.link %}
                          href="{{ block.settings.link }}"
                        {% else %}
                          role="link" aria-disabled="true"
                        {% endif %}
                        {% if block.settings.link_window %}
                          target="_blank"
                        {% endif %}
                        class="{% if block.settings.view_all_style == 'link' %}link underlined-link{% elsif block.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}">
                        {{- block.settings.button_label | escape -}}
                        {% if block.settings.show_icon %}
                          {% render 'icon-caret', icon: block.settings.show_icon %}
                        {% endif -%}
                      </a>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.button_label2 != blank -%}
                    <div class="banner__buttons">
                      <a
                        {% if block.settings.link2 %}
                          href="{{ block.settings.link2 }}"
                        {% else %}
                          role="link" aria-disabled="true"
                        {% endif %}
                        {% if block.settings.link_window2 %}
                          target="_blank"
                        {% endif %}
                        class="{% if block.settings.view_all_style2 == 'link' %}link underlined-link{% elsif block.settings.view_all_style2 == 'solid' %}button{% else %}button button--secondary{% endif %}">
                        {{- block.settings.button_label2 | escape -}}
                        {% if block.settings.show_icon2 %}
                          {% render 'icon-caret', icon: block.settings.show_icon2 %}
                        {% endif -%}
                      </a>
                    </div>
                  {%- endif -%}
                </div>
              </div>
          </div>
        </div>
        {%- style -%}
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__media::after {
            opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
          }
        {%- endstyle -%}
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 and section.settings.auto_rotate == false and section.settings.arrow_position == 'inline' -%}
      <div class="wb_home_sbtn slider-buttons no-js-hidden slideshow-inline-buttons">
        <button
          type="button"
          class="slider-button slider-button--prev button"
          name="previous"
          aria-label="{{ 'general.slider.previous_slide' | t }}"
          id="slider-button--prev-{{ section.id }}"
          aria-controls="slider-button--prev-{{ section.id }}">
          {% render 'icon-caret' %}
        </button>
        <button
          type="button"
          class="slider-button slider-button--next button"
          name="next"
          aria-label="{{ 'general.slider.next_slide' | t }}"
          id="slider-button--next-{{ section.id }}"
          aria-controls="slider-button--next-{{ section.id }}">
          {% render 'icon-caret' %}
        </button>
      </div>

    {%- elsif section.blocks.size > 1 and section.settings.auto_rotate == false and section.settings.arrow_position == 'bottom' or section.settings.arrow_position == 'slide_out' -%}
      <div class="{% if section.settings.arrow_position == 'slide_out' %}slide_out {% endif %}slideshow__controls slidshow-section--{{ section.id }} pagenation_align--{{ section.settings.slider_alignment }} wb_contrs slider-buttons no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %} {% unless section.settings.pagination_width == 'outside_container' %} page-width out__spacing{% endunless %}">
        <div class="wb_button_cover">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
          <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
            {%- if section.settings.slider_visual == 'counter' -%}
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ section.blocks.size }}</span>
            {%- else -%}
              <div class="slideshow__control-wrapper">
                {%- for block in section.blocks -%}
                  <button
                    class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                    aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                    aria-controls="Slider-{{ section.id }}"
                  >
                    {%- if section.settings.slider_visual == 'numbers' -%}
                      {{ forloop.index -}}
                    {%- elsif section.settings.slider_visual == 'dots' -%}
                      <span class="dot"></span>
                    {%- elsif section.settings.slider_visual == 'pagination_text' and block.settings.pagination_text != blank -%}
                      {{ block.settings.pagination_text }}
                      {%- else -%}
                      {{ 'sections.slideshow.pagination_text' | t }}
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>

          {%- if section.settings.auto_rotate -%}
            <button
              type="button"
              class="slideshow__autoplay slider-button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
              aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
            >
              {%- render 'icon-pause' -%}
              {%- render 'icon-play' -%}
            </button>
          {%- endif -%}
        </div>
      </div>
      <noscript>
        <div class="slider-buttons">
          <div class="slider-counter">
            {%- for block in section.blocks -%}
              <a href="#Slide-{{ section.id }}-{{ forloop.index }}" class="slider-counter__link link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}">
                {{ forloop.index }}
              </a>
            {%- endfor -%}
          </div>
        </div>
      </noscript>
    {%- endif -%}
  </slideshow-component>
</div>
{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
<script>
(function () {
  function initHeroAnimation() {
    const hero = document.querySelector(".hero-zoomout");
    if (!hero) return;
    hero.classList.remove("is-loaded");
    requestAnimationFrame(() => {
      setTimeout(() => {
        hero.classList.add("is-loaded");
      }, 100);
    });
  }
  document.addEventListener("DOMContentLoaded", initHeroAnimation);
  document.addEventListener("shopify:section:load", initHeroAnimation);
  document.addEventListener("shopify:section:select", initHeroAnimation);
})();
</script>

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "full_width",
          "label": "t:sections.slideshow.settings.layout.options__1.label"
        },
        {
          "value": "grid",
          "label": "t:sections.slideshow.settings.layout.options__2.label"
        }
      ],
      "default": "full_width",
      "label": "t:sections.slideshow.settings.layout.label"
    },
    {
      "type": "select",
      "id": "slide_height",
      "options": [
        {
          "value": "adapt_image",
          "label": "t:sections.slideshow.settings.slide_height.options__1.label"
        },
        { 
          "value": "small",
          "label": "t:sections.slideshow.settings.slide_height.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.slideshow.settings.slide_height.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.slideshow.settings.slide_height.options__4.label"
        },
        {
          "value": "fit_screen",
          "label": "Fit to screen"
        }
      ],
      "default": "medium",
      "label": "t:sections.slideshow.settings.slide_height.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.pagination.content"
