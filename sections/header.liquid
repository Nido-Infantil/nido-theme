  {% assign separatortop_opacity = section.settings.separatortop_opacity %}
  {% if section.settings.separatortop_opacity == 100 %}
    {% assign separatortop_opacity = 1000 %}
  {% endif %}
{%- style -%} 
  {% if section.settings.transparent_header == true %}
    .banner--fit_screen{
      height: 100vh;
    }
    {%  else %}
    .banner--fit_screen{
      height: calc(100vh - var(--header-height));
    }
  {% endif %}
  {% if section.settings.color_scheme == 'light' %}
  {% endif %}
  {% if section.settings.transparent_header == true %}
  :root {
    --color-trans-text : {{ section.settings.trans_text.red }},{{ section.settings.trans_text.green }},{{ section.settings.trans_text.blue }}
  }
  {% endif %}
  .page-index .transparent_header .scrolled-past-header .header-wrapper {
    box-shadow: 0px 2px 2px rgba(var(--color-foreground),.1);
  }
  .wbsimplemenuxs .list-menu__item{
    font-size: calc(var(--font-heading-scale) * {{ section.settings.menu_font }}px);
  }
  @media (min-width: 992px) and (max-width: 1199px) {
    .wbsimplemenuxs .list-menu__item{
      font-size: calc(var(--font-heading-scale) * {{ section.settings.menu_font | times: 0.85 | round: 0 }}px);
    }
  }
  {% if section.settings.enable_header_separator == true %}
    .page-index .header-wrapper.enable__separator {
      box-shadow: 0px 1px 1px rgba(var(--color-foreground),0.1);
    }
  {% endif %}
  {% if section.settings.transparent_header == true %}
    .page-index .header-wrapper.enable__separator {
      box-shadow: 0px 1px 1px rgba(var(--color-trans-text),{{ separatortop_opacity | divided_by: 1000.0 }});
    }
    .page-index .transparent_header .scrolled-past-header .header-wrapper {
      background: var(--gradient-background);
    }
    .page-index .transparent_header .wbmenuup.header__inline-menu {
      border-top-color: rgba(var(--color-trans-text), {{ separatortop_opacity | divided_by: 1000.0 }});
      background: transparent;
    }
    .page-index .tranhead.transparent_header .header__icon--menu.link svg{
      color: rgba(var(--color-trans-text));
    }
    /* .page-index .tranhead.transparent_header:not(:has(.wb_cart_bg)) .wbhcart svg path, */
    .page-index .tranhead.transparent_header:not(:has(.wb_cart_bg)) .wbhcart svg,
    .page-index .tranhead.transparent_header .userdrop svg,
    .page-index .tranhead.transparent_header .header__search .header__icon svg,
    .page-index .tranhead.transparent_header .wbheader_cont svg,
    .page-index .tranhead.transparent_header .header__icon--menu.link path {
      fill: rgba(var(--color-trans-text));
    }
    @media screen and (min-width: 768px) {
      .cshift_top .slideshow__text-wrapper {
        margin-top: 150px;
      }
    }
    @media screen and (min-width: 992px) {
      .page-index .transparent_header .header-wrapper.header_overlay::before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        opacity: 0.5;
        background: var(--gradient-background);
        z-index: -1;
      }
    }
    @media screen and (max-width: 767px) {
      .cshift_top:not(.mobile-text-below) .slideshow__text-wrapper {
        margin-top: 50px;
      }
    }
  {% endif %}

  header-drawer {
    justify-self: start;
  }
  {% for block in section.blocks %}
    {% if block.type == 'second-menu' %}
    .wbsecmenu.secondary-menu-{{ block.id }} ul.list-menu li:first-child a.highlighted_link svg {
      fill: {{ block.settings.icon_color }};
    }
    {% endif %}
  {% endfor %}

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 992px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  {%- if section.settings.menu == blank -%}
    @media screen and (min-width: 992px) {
      .gradient.wbmenuup.header__inline-menu {
        padding: 0;
      }
    }
  {%- endif -%}

  .psearch-hidden .header,
  .header{
    padding-top: {{ section.settings.padding_top | times: 0.8 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.8 | round: 0 }}px;
  }

  .section-header {
    position: sticky;
  }
  predictive-search:not([loading]) .predictive-search__loading-state, predictive-search:not([loading]) .predictive-search-status__loading {
      display: none;
  }
  @media screen and (min-width: 992px) {
    .psearch-hidden .header,
    .header{
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  } 
{%- endstyle -%}

