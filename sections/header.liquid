                    {%- elsif settings.wb_cartnumber == 'cart_text' -%}
                            <span class="medium-hide small-hide{% if section.settings.menu_uppercase %} menu-uppercase{% endif %}">{{ 'templates.cart.cart' | t }}</span>
                            <span class="wbhcartitemtext">({{ cart.item_count }})</span>
                    {%- else -%}
                      <span class="wbhcartitem wbqtyboth">{{ cart.item_count }}</span>
                          <span class="wbcarthtotal text-left">
                            <span>{{ 'templates.cart.cart' | t }}</span>
                          {%- if settings.currency_code_enabled -%}
                            <strong>{{ cart.total_price | money_with_currency }}</strong>
                          {%- else -%}
                            <strong>{{ cart.total_price | money }}</strong>
                          {%- endif -%}
                          </span>
                    {%- endif -%}
                  </button> 
                </div>
              </div>
              <div class="dropdown-menu dropdown-menu-right hidden color-{{ settings.drawer_color_scheme }} gradient" id="cartdrop">
                  <webi-cart-items class="{% if cart == empty %} is-empty{% endif %}">
                      <div class="cart__warnings">
                          <h5 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h5>
                      </div>
                      <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="webicart">
                          <div id="webi-main-cart-items" data-id="{{ section.id }}">
                              <div class="js-contents">
                                  {%- if cart != empty -%}
                                      {%- for item in cart.items -%}
                                          <div class="wbheadcartdrop" id="WbCartItem-{{ item.index | plus: 1 }}">
                                              <div class="wbcartdimg">
                                                  {% if item.image %}
                                                  {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                                                      <a href="{{ item.url }}">                                                          
                                                        {%- assign image_alt = item.image.alt | escape -%}
                                                        {%- assign image_height = 80 | divided_by: item.image.aspect_ratio | ceil -%}
                                                        {{ item.image | image_url: width: 80 | image_tag: alt: image_alt, loading: 'lazy', width: 80, height: image_height, class: 'img-fluid mx-auto' }}
                                                      </a>
                                                  {% endif %}
                                              </div>
                                              <div class="wbcartddesc">
                                                  {%- if settings.enable_vendor -%}
                                                      <p class="light"><small>{{ item.product.vendor }}</small></p>
                                                  {%- endif -%}
                                                  <a href="{{ item.url }}" class="wbcrtname">{{ item.product.title | escape }}</a>

                                                  {%- if item.original_price != item.final_price -%}
                                                    <div class="cart-item__discounted-prices item-price-wrapper price-inner">
                                                      <span class="visually-hidden">
                                                        {{ 'products.product.price.sale_price' | t }}
                                                      </span>
                                                      <div class="product-option price-original">
                                                        {%- if settings.currency_code_enabled -%}
                                                          {{ item.final_price | money_with_currency }}
                                                        {%- else -%}
                                                          {{ item.final_price | money }}
                                                        {%- endif -%}
                                                      </div>
                                                      <span class="visually-hidden">
                                                        {{ 'products.product.price.regular_price' | t }}
                                                      </span>
                                                      <span class="price-compare">
                                                        {%- if settings.currency_code_enabled -%}
                                                          {{ item.original_price | money_with_currency }}
                                                        {%- else -%}
                                                          {{ item.original_price | money }}
                                                        {%- endif -%}
                                                      </span>
                                                    </div>
                                                  {%- else -%}
                                                    <div class="item-price-wrapper price-inner">
                                                      <div class="product-option price-original">
                                                      {%- if settings.currency_code_enabled -%}
                                                        {{ item.original_price | money_with_currency }}
                                                      {%- else -%}
                                                        {{ item.original_price | money }}
                                                      {%- endif -%}
                                                      </div>
                                                      <span class="price-compare">
                                                        {%- if settings.currency_code_enabled -%}
                                                          {{ item.variant.compare_at_price | money_with_currency }}
                                                        {%- else -%}
                                                          {{ item.variant.compare_at_price | money }}
                                                        {%- endif -%}
                                                      </span>
                                                    </div>
                                                  {%- endif -%}
                                                  
                                                  {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != nil -%}
                                                      <dl>
                                                      {%- if item.product.has_only_default_variant == false -%}
                                                          {%- for option in item.options_with_values -%}
                                                              <div class="product-option">
                                                                  <dt>{{ option.name }}: </dt>
                                                                  <dd>{{ option.value }}</dd>
                                                              </div>
                                                          {%- endfor -%}
                                                      {%- endif -%}
                                                      {%- for property in item.properties -%}
                                                          {%- assign property_first_char = property.first | slice: 0 -%}
                                                          {%- if property.last != blank and property_first_char != '_' -%}
                                                              <div class="product-option">
                                                                  <dt>{{ property.first }}: </dt>
                                                                      <dd>
                                                                      {%- if property.last contains '/uploads/' -%}
                                                                          <a href="{{ property.last }}" class="link" target="_blank">{{ property.last | split: '/' | last }}</a>
                                                                      {%- else -%}
                                                                          {{ property.last }}
                                                                      {%- endif -%}
                                                                  </dd>
                                                              </div>
                                                          {%- endif -%}
                                                      {%- endfor -%}
                                                      </dl>
                                                      <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                                                  {%- endif -%}
                                                  <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                                                      {%- for discount in item.discounts -%}
                                                          <li class="discounts__discount">
                                                              {%- render 'icon-discount' -%}
                                                              {{ discount.title }}
                                                          </li>
                                                      {%- endfor -%}
                                                  </ul>
                                                  <webi-cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                                                      <a href="{{ item.url_to_remove }}" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}">
                                                          {% render 'icon-remove' %}
                                                      </a>
                                                  </webi-cart-remove-button>
                                              </div>
                                          </div>
                                      {%- endfor -%}
                                  {%- endif -%}
                              </div>
                          </div> 
                          <p class="visually-hidden" id="webi-cart-live-region-text" aria-live="polite" role="status"></p>
                          <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
                      </form>
                  </webi-cart-items>
                  <div class="{% if cart == empty %} is-empty{% endif %}" id="webi-main-cart-footer" data-id="{{ section.id }}">
                      <div class="cart__blocks">
                          <div class="js-contents" {{ block.shopify_attributes }}>
                              <div class="totals">
                                  <p>{{ 'sections.cart.subtotal' | t }}</p>
                                  <h3>{{ cart.total_price | money_with_currency }}</h3>
                              </div>
                              <div>
                                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                                      <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                                          {%- for discount in cart.cart_level_discount_applications -%}
                                              <li class="discounts__discount discounts__discount--end text-right">
                                                  {%- render 'icon-discount' -%}
                                                  {{ discount.title }}
                                                  (-{{ discount.total_allocated_amount | money }})
                                              </li>
                                          {%- endfor -%}
                                      </ul>
                                  {%- endif -%}
                              </div>
                          </div>  
                          <div class="cart__ctas" {{ block.shopify_attributes }}>
                              <noscript>
                                  <button type="submit" class="cart__update-button button button--secondary" form="cart">{{ 'sections.cart.update' | t }}</button>
                              </noscript>
                              <a href="{{ routes.cart_url }}" class="button button--primary">{{ 'wbcustomlabel.wballtext.viewcart' | t }}</a>
                              <button type="submit" id="checkout" class="button button--primary" name="checkout" form="webicart">
                                {{ 'sections.cart.checkout' | t }}
                              </button>
                          </div>
                      </div>
                  </div>
              </div>
            </cart-drop>
            {%- endif -%}
            {% comment %} Cart Dropdown Over {% endcomment %}

      </div>
  </header>
</div>

{%- capture sec_menu_center -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'second-menu' and block.settings.sec_menu_position == 'bottom' -%}
      {%- if block.settings.sec_menu_alignment == 'center' -%} sec--menu-center {% else %} sec--menu-right{%- endif -%}
    {%- endif -%}
  {%- endfor -%}  
{%- endcapture -%}

{% comment %} Menu {% endcomment %}
    {%- unless section.settings.logo_position == 'middle-left' or section.settings.logo_position == 'left-middle' -%}
      {%- if section.settings.menu_type_desktop == 'mega' -%}
        <div class="color-{{ section.settings.color_schememenu }} gradient wbmenuup header__inline-menu">
          <div class="{% if section.settings.full-width == true %}full-page-width {% else %}page-width {% endif %}wbmenubtm {% if section.settings.menu_alignment == 'center' %} main--menu-center{% endif %} {{ sec_menu_center }}"> 
            {%- if section.settings.menu != blank -%}
            <desktop-webi-menu class="wbsimplemenuxs bottom-menu-items{% if section.settings.menu_alignment == 'left' %} main-menu-left{% endif %}{% if section.settings.menu_alignment == 'center' %} main-menu-center{% endif %}" data-drop="mouseover">
                <ul class="list-menu list-menu--inline badge_gap_space" role="list">
                {%- for link in section.settings.menu.links -%}
                  {%- liquid 
                    assign assignsubmenu = true
                    assign displaymegamenu = false
                    assign blank_link = false
                    assign onlymenulink = false                    
                    assign image_position = ''
                    assign has_block = false
                    for block in section.blocks
                      assign case_title = block.settings.menuname | downcase
                      assign lower_title = link.title | downcase
                      if lower_title == case_title
                          assign displaymegamenu = true
                          if block.settings.showsubmenu == false
                              assign assignsubmenu = false
                              assign onlymenulink = true
                          endif
                          if link.links == blank
                              assign blank_link = lower_title
                          endif
                          if block.settings.bnrimg != blank or block.settings.bnrlink != blank
                            assign sbnr = 'mega_singlebnr'
                          endif                          
                          assign image_position = block.settings.image_position
                          assign has_block = true
                          break
                      endif
                    endfor
                  -%}
                  <li {% if has_menu_badge %}class="badge_space"{% endif %}> 
                      {% for block in section.blocks %}
                        {% if block.type == 'menu-badge' %}
                          {% liquid
                            assign badge_case_title = block.settings.badgemenuname | downcase
                          %}
                        {% if lower_title == badge_case_title %}
                          {% if block.settings.badge.size and block.settings.badge != blank %}
                            <div class="badge__position">
                            <span class="menu_badge menu_badge--{{ block.id }}" style="background-color: {{ block.settings.badge_bg }}; color:{{ block.settings.badge_text }};fill:{{ block.settings.badge_text }};">{{ block.settings.badge }}</span></div>{% endif %}
                        {% endif %} 
                        {% style %}
                          .menu_badge--{{ block.id }}::before {
                              border-bottom-color: {{ block.settings.badge_bg }};
                          }
                        {% endstyle %}
                        {% endif %}
                      {% endfor %}
                      {%- if link.links != blank -%}
                        <details-disclosure>
                          {% if onlymenulink %}
                            <a href="{{ link.url }}" class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset"{% if link.current %} aria-current="page"{% endif %}>
                              <span {%- if link.current %} class="header__active-menu-item"{% endif %}>{{ link.title | escape }}</span>
                            </a>
                          {% endif %}
                          {% if assignsubmenu %}
                            <details id="Details-HeaderMenu-{{ forloop.index }}" class="header-mega--menu">
                              <summary class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link focus-inset">
                                <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                                  {% if section.settings.show_menu_link == true %}
                                <a href="{{ link.url }}" class="">
                              {% endif %}
                                  {{ link.title | escape }}
                              {% if section.settings.show_menu_link == true %}
                                </a>
                              {% endif %}
                                </span>
                                {% render 'icon-caret' %}
                              </summary>
                              <div id="HeaderMenu-MenuList-{{ forloop.index }}" class="color-{{ section.settings.color__dropmenu }} gradient header__submenu {% if link.links.size < 4 and displaymegamenu == false %}hsmenucont{% endif %} list-menu list-menu--disclosure caption-large motion-reduce {% if link.links.size > 3 or displaymegamenu %}wbmenufull{% endif %}" tabindex="-1">
                                      <div class="{% if section.settings.full-width == true %}full-page-width{% else %}container{% endif %} {% if link.links.size < 4 %}menu-space{% endif %}">
                                        {% if image_position == 'beside_menu' and has_block %}
                                          <div class="sbanner_{{ image_position }}">
                                        {% endif %}
                                          <div class="row {% if link.levels == 1 %} mega-menu__list--condensed{% endif %} {% if link.links.size == 4 and displaymegamenu == true %}{{ sbnr }} {% endif %}{% if link.links.size < 4 or link.links.size > 4 %}wb-lnk{{ sbnr }}{% endif %} menu_list_column">
                                            {%- for childlink in link.links -%}
                                            <div class="{% if link.links.size == 1 %}col-12 {% elsif link.links.size == 2 %}col-6 {% elsif link.links.size == 3 %}col-4 {% else %}col-3 {% endif %}">
                                              <div class="wbmenuinner">
                                                <div class="menu-item-with-badge">
                                                  <a href="{{ childlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if childlink.current %} list-menu__item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                                    {{ childlink.title | escape }}
                                                  </a>
                                                  {% for block in section.blocks %}
                                                    {% if block.type == 'menu-badge' %}
                                                      {% liquid
                                                        assign badge_case_title = block.settings.badgemenuname | downcase
                                                        assign child_title = childlink.title | downcase
                                                      %}
                                                      {% if child_title == badge_case_title %}
                                                        {% if block.settings.badge != blank %}
                                                          <span class="menu_badge_child menu_badge--{{ block.id }}"
                                                            style="background-color: {{ block.settings.badge_bg }};
                                                                  color: {{ block.settings.badge_text }};
                                                                  fill: {{ block.settings.badge_text }};">
                                                            {{ block.settings.badge }}
                                                          </span>
                                                        {% endif %}
                                                      {% endif %}
                                                    {% endif %}
                                                  {% endfor %}
                                                </div>
                                                  <ul class="header__submenu list-menu motion-reduce">
                                                    {%- for grandchildlink in childlink.links -%}
                                                      <li>
                                                        <div class="menu-item-with-badge">
                                                          <a href="{{ grandchildlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if grandchildlink.current %} list-menu__item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                            {{ grandchildlink.title | escape }}
                                                          </a>
                                                          {% for block in section.blocks %}
                                                            {% if block.type == 'menu-badge' %}
                                                              {% liquid
                                                                assign badge_case_title = block.settings.badgemenuname | downcase
                                                                assign grandchild_title = grandchildlink.title | downcase
                                                              %}
                                                              {% if grandchild_title == badge_case_title %}
                                                                {% if block.settings.badge != blank %}
                                                                  <span class="menu_badge_child menu_badge--{{ block.id }}"
                                                                    style="background-color: {{ block.settings.badge_bg }};
                                                                          color: {{ block.settings.badge_text }};
                                                                          fill: {{ block.settings.badge_text }};">
                                                                    {{ block.settings.badge }}
                                                                  </span>
                                                                {% endif %}
                                                              {% endif %}
                                                            {% endif %}
                                                          {% endfor %}
                                                        </div>
                                                      </li>
                                                    {%- endfor -%}
                                                  </ul>
                                                  </div>
                                                </div>
                                            {%- endfor -%}
                                          </div>
                                          {% render 'megamenu-banner', blocks: section.blocks, title: link.title %}
                                        {% if image_position == 'beside_menu' and has_block %}
                                          </div>
                                        {% endif %}
                                      </div>
                                  {% render 'megamenu', blocks: section.blocks, title: link.title %}
                              </div>
                            </details>
                          {% endif %}
                        </details-disclosure>
                      {%- else -%}
                        {% if blank_link %}
                          <details-disclosure>
                            {% if onlymenulink %}
                                <a href="{{ link.url }}" class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset"{% if link.current %} aria-current="page"{% endif %}>
                                  <span {%- if link.current %} class="header__active-menu-item"{% endif %}>{{ link.title | escape }}</span>
                                </a>
                            {% endif %}
                            {% if assignsubmenu %}
                              <details id="Details-HeaderMenu-{{ forloop.index }}" class="header-mega--menu">
                                <summary class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link focus-inset">
                                  <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                                    {% if section.settings.show_menu_link == true %}
                                <a href="{{ link.url }}" class="">
                              {% endif %}
                                  {{ link.title | escape }}
                              {% if section.settings.show_menu_link == true %}
                                </a>
                              {% endif %}
                                  </span>
                                    {% render 'icon-caret' %}
                                  </summary>
                                  <div id="HeaderMenu-MenuList-{{ forloop.index }}" class="color-{{ section.settings.color__dropmenu }} gradient header__submenu {% if link.links.size < 4 and displaymegamenu == false %}hsmenucont{% endif %} list-menu list-menu--disclosure caption-large motion-reduce {% if link.links.size > 3 or displaymegamenu %}wbmenufull{% endif %}" tabindex="-1">
                                    <div class="{% if section.settings.full-width == true %}full-page-width{% else %}container{% endif %}">
                                      {% if image_position == 'beside_menu' and has_block %}
                                        <div class="sbanner_{{ image_position }}">
                                      {% endif %}
                                        <div class="row {% if link.links.size == 4 and displaymegamenu == true %}{{ sbnr }} {% endif %}{% if link.links.size < 4 or link.links.size > 4 %}wb-lnk{{ sbnr }}{% endif %} menu_list_column">
                                        </div>
                                        {% render 'megamenu-banner', blocks: section.blocks, title: link.title %}
                                      {% if image_position == 'beside_menu' and has_block %}
                                        </div>
                                      {% endif %}
                                    </div>
                                    {% render 'megamenu', blocks: section.blocks, title: link.title %}
                                  </div>
                              </details>
                            {% endif %}
                          </details-disclosure>
                        {% assign blank_link = false %}
                        {% else %}
                          <a href="{{ link.url }}" class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset"{% if link.current %} aria-current="page"{% endif %}>
                            <span {%- if link.current %} class="header__active-menu-item"{% endif %}>{{ link.title | escape }}</span>
                          </a>
                        {% endif %}
                      {%- endif -%}
                    </li>
                {%- endfor -%}    
                </ul>
              </desktop-webi-menu>
            {%- endif -%}
      
            {%- for block in section.blocks -%}
              {%- if block.settings.secmenu != blank and block.settings.sec_menu_position == 'bottom' or section.settings.logo_position == 'top-left' -%}
                <nav class="wbsecmenu secondary-menu-{{ block.id }} {% if section.settings.menu == blank %} wbsecmenupad{% endif %}{% if block.settings.sec_menu_alignment == 'center' %} sec-menu-center{% endif %}{% if block.settings.sec_menu_alignment == 'right' %} sec-menu-right{% endif %}">
                  <ul class="list-menu list-menu--inline" role="list">
                  {%- for link in block.settings.secmenu.links -%}
                      <li>
                        <a href="{{ link.url }}" class="{% if forloop.first %}highlighted_link{% endif %}">
                          {% if forloop.first %}
                            <span class="multis-svg">{% render 'icon-accordion', icon: block.settings.icon1 %}</span>
                          {% endif %}
                          <span>{{ link.title | escape }}</span>
                        </a>
                      </li>
                  {%- endfor -%}
                  </ul>
                </nav>
              {%- endif -%}
            {% endfor %}
          </div>
        </div>
      {%- elsif section.settings.menu_type_desktop != 'drawer' -%}
        <nav class="color-{{ section.settings.color_schememenu }} gradient wbmenuup header__inline-menu">
          <div class="{% if section.settings.full-width == true %}full-page-width {% else %}page-width {% endif %}wbmenubtm{% if section.settings.menu_alignment == 'center' %} main--menu-center{% endif %} {{ sec_menu_center }}">
            {%- if section.settings.menu != blank -%}
            <ul class="list-menu list-menu--inline bottom-menu-items{% if section.settings.menu_alignment == 'left' %} main-menu-left{% endif %}{% if section.settings.menu_alignment == 'center' %} main-menu-center{% endif %}" role="list">
              {%- for link in section.settings.menu.links -%}
                <li>
                  {%- if link.links != blank -%}
                    <header-menu>
                      <details id="Details-HeaderMenu-{{ forloop.index }}">
                        <summary class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link focus-inset">
                          <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                            {% if section.settings.show_menu_link == true %}
                                <a href="{{ link.url }}" class="">
                              {% endif %}
                                  {{ link.title | escape }}
                              {% if section.settings.show_menu_link == true %}
                                </a>
                              {% endif %}
                          </span>
                          {% render 'icon-caret' %}
                        </summary>
                        <ul id="HeaderMenu-MenuList-{{ forloop.index }}" class="color-{{ section.settings.color__dropmenu }} gradient header__submenu list-menu list-menu--disclosure gradient caption-large motion-reduce global-settings-popup" role="list" tabindex="-1">
                          {%- for childlink in link.links -%}
                            <li>
                              {%- if childlink.links == blank -%}
                                <a href="{{ childlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if childlink.current %} list-menu__item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                  {{ childlink.title | escape }}
                                </a>
                              {%- else -%}
                                <details id="Details-HeaderSubMenu-{{ forloop.index }}">
                                  <summary class="header__menu-item link link--text list-menu__item focus-inset caption-large">
                                    <span>{{ childlink.title | escape }}</span>
                                    {% render 'icon-caret' %}
                                  </summary>
                                  <ul class="header__submenu list-menu motion-reduce">
                                    {%- for grandchildlink in childlink.links -%}
                                      <li>
                                        <a href="{{ grandchildlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if grandchildlink.current %} list-menu__item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                          {{ grandchildlink.title | escape }}
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </details>
                              {%- endif -%}
                            </li>
                          {%- endfor -%}
                        </ul>
                      </details>
                    </header-menu>
                  {%- else -%}
                    <a href="{{ link.url }}" class="header__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset"{% if link.current %} aria-current="page"{% endif %}>
                      <span {%- if link.current %} class="header__active-menu-item"{% endif %}>{{ link.title | escape }}</span>
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

            {%- for block in section.blocks -%}
              {%- if block.settings.secmenu != blank and block.settings.sec_menu_position == 'bottom' -%}
                <nav class="wbsecmenu secondary-menu-{{ block.id }} {% if section.settings.menu == blank %} wbsecmenupad{% endif %}{% if block.settings.sec_menu_alignment == 'center' %} sec-menu-center{% endif %}{% if block.settings.sec_menu_alignment == 'right' %} sec-menu-right{% endif %}">
                  <ul class="list-menu list-menu--inline" role="list">
