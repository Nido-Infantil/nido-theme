{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
    if block.type == 'menu-badge'
      assign badge__menu = block.settings.badgemenuname
    endif
  endfor
  if section.blocks.size > 0
    assign has_menu_badge = false
    for block in section.blocks
      if block.type == 'menu-badge'
        assign has_menu_badge = true
      endif
    endfor
  endif
    assign has_sec_menu = false
    for block in section.blocks
      if block.type == 'second-menu'
        assign has_sec_menu = true
      endif
    endfor
-%}

<{% if section.settings.sticky_header_type != 'none' %}sticky-header data-sticky-type="{{ section.settings.sticky_header_type }}"{% else %}div{% endif %} data-menuclick="{{ section.settings.menuclick }}" class="header-wrapper {% if section.settings.transparent_header == true and template.name == 'index' %} tranhead transparent_header{% endif %} {% if section.settings.enable_header_separator == true %} enable__separator {% endif %} {% if section.settings.enable_header_overlay == true %}header_overlay {% endif %}color-{{ section.settings.color_scheme }} gradient header-wrapper--border-bottom {% if section.settings.menu_type_desktop == 'dropdown' %} dropm-menu{% endif %}" data-trans="{{ section.settings.transparent_header }}" data-trans_header_bg="false">
<div class="{% if section.settings.full-width == true %}full-page-width{% else %}page-width{% endif %}">
  <header class="header header--{{ section.settings.logo_position }} header--mobile-left {% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if settings.wb_cartnumber == 'wb_shoptotal' or settings.wb_cartnumber == 'wb_shopqtytotal' %} wbcartbth{% endif %}">
    {%- if section.settings.menu != blank -%}
      <header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
        <details id="Details-menu-drawer-container" class="menu-drawer-container">
          <summary class="header__icon header__icon--menu header__icon--summary link focus-inset" aria-label="{{ 'sections.header.menu' | t }}">
            <span>
              {% render 'icon-hamburger' %}
              {% render 'icon-close' %}
            </span>
          </summary>
          <div id="menu-drawer" class="color-{{ section.settings.color__dropmenu }} gradient menu-drawer motion-reduce" tabindex="-1">
            <div class="menu-drawer__inner-container">
              <div class="menu-drawer__navigation-container">
                <nav class="menu-drawer__navigation">

                  <div class="sticky-menu-drawer_links">
                    {%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
                      <div class="menu-drawer__localization header__localization">
                        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                          <localization-form>
                            {%- form 'localization', id: 'HeaderLanguageMobileForm', class: 'localization-form' -%}
                              <div class="no-js-hidden">
                                {%- render 'language-localization', localPosition: 'HeaderLanguageMobile' -%}
                              </div>
                            {%- endform -%}
                          </localization-form>
                        {%- endif -%}
                        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                          <localization-form>
                            {%- form 'localization', id: 'HeaderCountryMobileForm', class: 'localization-form' -%}
                              <div class="no-js-hidden">
                                {%- render 'country-localization', localPosition: 'HeaderCountryMobile' -%}
                              </div>
                            {%- endform -%}
                          </localization-form>
                        {% endif %}
                      </div>
                    {%- endif -%}
                  </div>
              
                  <ul class="menu-drawer__menu has-submenu list-menu" role="list">
                    {%- if section.settings.menu_type_desktop == 'mega' or section.settings.menu_type_desktop == 'drawer' -%}
                      {%- for link in section.settings.menu.links -%}
                        {%- liquid 
                          assign assignsubmenu = true
                         assign blank_link = false
                         assign onlymenulink = false
                          assign image_position = ''
                          assign has_block = false
                         for block in section.blocks
                             assign case_title = block.settings.menuname | downcase
                             assign lower_title = link.title | downcase
                             if lower_title == case_title
                                if block.settings.showsubmenu == false
                                  assign assignsubmenu = false
                                  assign onlymenulink = true
                                endif
                                if link.links == blank 
                                  assign blank_link = lower_title
                                endif
                                if block.settings.bnrimg != blank or block.settings.bnrlink != blank
                                  assign sbnr = 'mega_singlebnr'
                                endif
                                assign image_position = block.settings.image_position
                                assign has_block = true
                                break
                             endif
                         endfor 
                        -%}
                        <li>
                          {%- if link.links != blank -%}
                            {% if onlymenulink %}
                              <a href="{{ link.url }}" class="menu-drawer__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>
                                {{ link.title | escape }}
                                {% for block in section.blocks %}
                                  {% if block.type == 'menu-badge' %}
                                    {%- liquid
                                      assign badge_case_title = block.settings.badgemenuname | downcase
                                    -%}
                                  {% if lower_title == badge_case_title %}
                                    {% if block.settings.badge.size and block.settings.badge != blank %}
                                      <div class="badge__position">
                                      <span class="menu_badge menu_badge--{{ block.id }}" style="background-color: {{ block.settings.badge_bg }}; color:{{ block.settings.badge_text }};fill:{{ block.settings.badge_text }};">{{ block.settings.badge }}</span></div>{% endif %}
                                  {% endif %} 
                                  {% style %}
                                    .menu_badge--{{ block.id }}::before {
                                        border-bottom-color: {{ block.settings.badge_bg }};
                                    }
                                  {% endstyle %}
                                  {% endif %}
                                {% endfor %}
                              </a>
                            {% endif %}
                            {% if assignsubmenu %}
                              <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                                <summary class="menu-drawer__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}">
                                  {% if section.settings.show_menu_link == true %}
                                <a href="{{ link.url }}" class="">
                              {% endif %}
                                  {{ link.title | escape }}
                              {% if section.settings.show_menu_link == true %}
                                </a>
                              {% endif %}
                                  {% for block in section.blocks %}
                                    {% if block.type == 'menu-badge' %}
                                      {%- liquid
                                        assign badge_case_title = block.settings.badgemenuname | downcase
                                      -%}
                                    {% if lower_title == badge_case_title %}
                                      {% if block.settings.badge.size and block.settings.badge != blank %}
                                        <div class="badge__position">
                                        <span class="menu_badge menu_badge--{{ block.id }}" style="background-color: {{ block.settings.badge_bg }}; color:{{ block.settings.badge_text }};fill:{ block.settings.badge_text }};">{{ block.settings.badge }}</span></div>{% endif %}
                                    {% endif %} 
                                    {% style %}
                                      .menu_badge--{{ block.id }}::before {
                                          border-bottom-color: {{ block.settings.badge_bg }};
                                      }
                                    {% endstyle %}
                                    {% endif %}
                                  {% endfor %}
                                  {% render 'icon-arrow' %}
                                  {% render 'icon-caret' %}
                                </summary>
                                <div id="link-{{ link.handle | escape }}" class="menu-drawer__submenu has-submenu gradient motion-reduce" tabindex="-1">
                                  <div class="menu-drawer__inner-submenu">
                                    <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                                      {% render 'icon-arrow' %}
                                      {% if section.settings.show_menu_link == true %}
                                <a href="{{ link.url }}" class="">
                              {% endif %}
                                  {{ link.title | escape }}
                              {% if section.settings.show_menu_link == true %}
                                </a>
                              {% endif %}
                                    </button>
                                    <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                      {% if assignsubmenu %}
                                        {%- for childlink in link.links -%}
                                          <li>
                                            {%- if childlink.links == blank -%}
                                              <div class="menu-item-with-badge">
                                                <a href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                                  {{ childlink.title | escape }}
                                                </a>
                                                {% for block in section.blocks %}
                                                  {% if block.type == 'menu-badge' %}
                                                    {% liquid
                                                      assign badge_case_title = block.settings.badgemenuname | downcase
                                                      assign child_title = childlink.title | downcase
                                                    %}
                                                    {% if child_title == badge_case_title %}
                                                      {% if block.settings.badge != blank %}
                                                        <span class="menu_badge_child menu_badge--{{ block.id }}"
                                                          style="background-color: {{ block.settings.badge_bg }};
                                                                color: {{ block.settings.badge_text }};
                                                                fill: {{ block.settings.badge_text }};">
                                                          {{ block.settings.badge }}
                                                        </span>
                                                      {% endif %}
                                                    {% endif %}
                                                  {% endif %}
                                                {% endfor %}
                                              </div>
                                            {%- else -%}
                                              <details>
                                                <summary class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
                                                  {{ childlink.title | escape }}
                                                  {% for block in section.blocks %}
                                                      {% if block.type == 'menu-badge' %}
                                                        {% liquid
                                                          assign badge_case_title = block.settings.badgemenuname | downcase
                                                          assign child_title = childlink.title | downcase
                                                        %}
                                                        {% if child_title == badge_case_title %}
                                                          {% if block.settings.badge != blank %}
                                                            <span class="menu_badge_child menu_badge--{{ block.id }}"
                                                              style="background-color: {{ block.settings.badge_bg }};
                                                                    color: {{ block.settings.badge_text }};
                                                                    fill: {{ block.settings.badge_text }};">
                                                              {{ block.settings.badge }}
                                                            </span>
                                                          {% endif %}
                                                        {% endif %}
                                                      {% endif %}
                                                    {% endfor %}
                                                  {% render 'icon-arrow' %}
                                                  {% render 'icon-caret' %}
                                                </summary>
                                                <div id="childlink-{{ childlink.handle | escape }}" class="menu-drawer__submenu has-submenu gradient motion-reduce">
                                                  <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                                                    {% render 'icon-arrow' %}
                                                    {{ childlink.title | escape }}
                                                  </button>
                                                  <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                                    {%- for grandchildlink in childlink.links -%}
                                                      <li>
                                                        <a href="{{ grandchildlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                          {{ grandchildlink.title | escape }}
                                                          {% for block in section.blocks %}
                                                            {% if block.type == 'menu-badge' %}
                                                              {% liquid
                                                                assign badge_case_title = block.settings.badgemenuname | downcase
                                                                assign grandchild_title = grandchildlink.title | downcase
                                                              %}
                                                              {% if grandchild_title == badge_case_title %}
                                                                {% if block.settings.badge != blank %}
                                                                  <span class="drawer_gchild menu_badge_child menu_badge--{{ block.id }}"
                                                                    style="background-color: {{ block.settings.badge_bg }};
                                                                          color: {{ block.settings.badge_text }};
                                                                          fill: {{ block.settings.badge_text }};">
                                                                    {{ block.settings.badge }}
                                                                  </span>
                                                                {% endif %}
                                                              {% endif %}
                                                            {% endif %}
                                                          {% endfor %}
                                                        </a>
                                                      </li>
                                                    {%- endfor -%}
                                                  </ul>
                                                </div>
                                              </details>
                                            {%- endif -%}
                                          </li>
                                        {%- endfor -%}
                                        <div class="drawer_sbanner sbanner_{{ image_position }}">
                                          {% render 'megamenu-banner', blocks: section.blocks, title: link.title %}
                                        </div>
                                      {% endif %}
                                      {% render 'megamenu', blocks: section.blocks, title: link.title %}
                                    </ul>
                                  </div>
                                </div>
                              </details>
                            {% endif %}
                          {%- else -%}
                            {% if blank_link %}
                              {% if onlymenulink %}
                                <a href="{{ link.url }}" class="menu-drawer__menu-item {% if section.settings.menu_uppercase %}menu-uppercase{% endif %} list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>
                                {{ link.title | escape }}
                                {% for block in section.blocks %}
                                  {% if block.type == 'menu-badge' %}
                                    {%- liquid
                                      assign badge_case_title = block.settings.badgemenuname | downcase
                                    -%}
                                  {% if lower_title == badge_case_title %}
                                    {% if block.settings.badge.size and block.settings.badge != blank %}
                                      <div class="badge__position">
                                      <span class="menu_badge menu_badge--{{ block.id }}" style="background-color: {{ block.settings.badge_bg }}; color:{{ block.settings.badge_text }};fill:{{ block.settings.badge_text }};">{{ block.settings.badge }}</span></div>{% endif %}
                                  {% endif %} 
